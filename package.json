{
  "name": "PROJECT_NAME",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next",
    "build": "next build && next export",
    "start": "next start",
    "type-check": "tsc",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:css": "stylelint 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "codegen": "graphql-codegen --config graphql-codegen.js -r dotenv/config"
  },
  "dependencies": {
    "next": "^10.0.6",
    "react": "^17.0.1",
    "react-datocms": "^1.5.0",
    "react-dom": "^17.0.1",
    "react-focus-lock": "^2.5.0",
    "rect": "^1.2.1",
    "styled-components": "^5.2.1",
    "styled-sanitize": "^1.1.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^1.20.1",
    "@graphql-codegen/typescript": "^1.21.0",
    "@strv/eslint-config-react": "^3.1.2",
    "@strv/eslint-config-typescript": "^2.3.0",
    "@strv/stylelint-config-styled-components": "^1.1.1",
    "@types/node": "^14.14.25",
    "@types/react": "^17.0.1",
    "@types/react-dom": "^17.0.0",
    "@types/styled-components": "^5.1.7",
    "babel-eslint": "^10.1.0",
    "babel-plugin-root-import": "^6.6.0",
    "babel-plugin-styled-components": "^1.12.0",
    "dotenv": "^8.2.0",
    "eslint": "^7.19.0",
    "eslint-config-prettier": "^7.2.0",
    "eslint-plugin-import": "^2.22.0",
    "git-aliases-semantic-commits": "^0.4.1",
    "graphql": "^15.5.0",
    "husky": "^5.0.9",
    "lint-staged": "^10.5.4",
    "prettier": "^2.2.1",
    "stylelint": "^13.10.0",
    "stylelint-config-prettier": "^8.0.2",
    "typescript": "^4.1.5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "yarn type-check"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "stylelint",
      "prettier --write"
    ],
    "*.{json,md,html}": [
      "prettier --write"
    ]
  }
}
