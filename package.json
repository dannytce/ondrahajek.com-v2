{
  "name": "ondrahajek.com",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "type-check": "astro check",
    "lint": "oxlint src scripts",
    "format": "prettier --write \"src/**/*.{ts,astro}\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,astro}\" \"scripts/**/*.ts\"",
    "codegen": "graphql-codegen -r dotenv/config --config graphql-codegen.cjs",
    "import:portfolio": "tsx scripts/import-portfolio.ts",
    "update:portfolio": "tsx scripts/import-portfolio.ts --update-only",
    "export:portfolio": "tsx scripts/export-portfolio-csv.ts",
    "import:references": "tsx scripts/import-clients-locations-tags.ts",
    "sync:subcategories": "tsx scripts/sync-portfolio-subcategories.ts",
    "datocms:item-counts": "tsx scripts/datocms-item-counts.ts",
    "generate:tag-labels": "tsx scripts/generate-portfolio-tag-labels.ts",
    "generate:fonts:chars": "node scripts/generate-font-subset/get-characters.mjs",
    "generate:fonts:subset": "bash scripts/generate-font-subset/run-subset.sh",
    "generate:fonts": "pnpm build && pnpm generate:fonts:chars && pnpm generate:fonts:subset"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^5.1.0",
    "@datocms/astro": "^0.6.12",
    "astro": "^5.0.3",
    "toastify-js": "^1.12.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@datocms/cma-client-node": "^5.3.0",
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/typescript": "^4.1.6",
    "@types/node": "^22.10.0",
    "@types/toastify-js": "^1.12.4",
    "cheerio": "^1.0.0",
    "csv-parse": "^6.2.1",
    "datocms-structured-text-utils": "^5.1.7",
    "dotenv": "^8.2.0",
    "graphql": "^15.5.0",
    "oxlint": "^1.58.0",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.astro": [
      "prettier --write"
    ],
    "*.{json,md,html,css}": [
      "prettier --write"
    ]
  }
}
