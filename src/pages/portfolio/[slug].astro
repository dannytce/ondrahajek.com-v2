---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Page from '~/components/Page.astro';
import { Header } from '~/components/Header';
import { Portfolio } from '~/components/Portfolio';
import { getAllPortfolios, getAllPortfoliosWithSlug, getHeaderBackgroundByPage } from '~/api';

export async function getStaticPaths() {
  const portfolios = await getAllPortfoliosWithSlug();
  return portfolios.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const portfolios = await getAllPortfolios();
const headerBackground = await getHeaderBackgroundByPage('/');
---

<BaseLayout title={`${slug} - ondrahajek.com | AERIAL Video & Photography`}>
  <Page isHomepage>
    <Header
      slot="header"
      client:load
      title="Aerial"
      subTitle="Video &amp; Photography"
      headerBackground={headerBackground}
      isHomepage
      currentPath={Astro.url.pathname}
    />
    <Portfolio client:load portfolios={portfolios} slug={slug} />
  </Page>
</BaseLayout>
