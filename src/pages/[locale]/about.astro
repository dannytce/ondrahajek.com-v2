---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Page from '~/components/Page.astro';
import Header from '~/components/Header.astro';
import Section from '~/components/About/Section.astro';
import { getHeaderBackgroundByPage } from '~/api';
import { localeStaticPaths, getLocaleFromParam, t } from '~/i18n';

export function getStaticPaths() {
  return localeStaticPaths();
}

const locale = getLocaleFromParam(Astro.params.locale);
const headerBackground = await getHeaderBackgroundByPage('/about');
---

<BaseLayout
  title={`${t(locale, 'nav.about')} - ${t(locale, 'meta.title')}`}
  locale={locale}
  canonicalPath="/about"
>
  <Page isAboutPage locale={locale}>
    <Header
      slot="header"
      title={t(locale, 'nav.about')}
      headerBackground={headerBackground}
      isAboutPage
      currentPath={`/${locale}/about`}
      locale={locale}
      pagePath="/about"
    />
    <Section title="Cool numbers">
      <ul class="p-0 m-0 list-none md:flex md:justify-around">
        <li class="flex-1">
          <h3 class="uppercase font-teko text-[#49494b] text-[2rem] md:text-[3rem] lg:text-[4rem]">
            <strong class="text-white block leading-none text-[6rem] sm:text-[7rem] sm:leading-tight md:text-[8rem] lg:text-[10rem] lg:leading-snug xl:text-[12rem]">
              135
            </strong>
            Projects
          </h3>
        </li>
        <li class="flex-1">
          <h3 class="uppercase font-teko text-[#49494b] text-[2rem] md:text-[3rem] lg:text-[4rem]">
            <strong class="text-white block leading-none text-[6rem] sm:text-[7rem] sm:leading-tight md:text-[8rem] lg:text-[10rem] lg:leading-snug xl:text-[12rem]">
              22
            </strong>
            Different countries
          </h3>
        </li>
        <li class="flex-1">
          <h3 class="uppercase font-teko text-[#49494b] text-[2rem] md:text-[3rem] lg:text-[4rem]">
            <strong class="text-white block leading-none text-[6rem] sm:text-[7rem] sm:leading-tight md:text-[8rem] lg:text-[10rem] lg:leading-snug xl:text-[12rem]">
              800+
            </strong>
            Flight hours
          </h3>
        </li>
      </ul>
    </Section>

    <Section title="I can help with" gray>
      <ul class="list-none p-0 m-0">
        <li class="uppercase text-[3rem] md:text-[4rem] leading-none font-teko font-semibold text-secondary my-[10px] py-[10px] transition-colors duration-200 hover:text-white">
          Documentary
        </li>
        <li class="uppercase text-[3rem] md:text-[4rem] leading-none font-teko font-semibold text-secondary my-[10px] py-[10px] transition-colors duration-200 hover:text-white">
          Film
        </li>
        <li class="uppercase text-[3rem] md:text-[4rem] leading-none font-teko font-semibold text-secondary my-[10px] py-[10px] transition-colors duration-200 hover:text-white">
          Commercial promo
        </li>
        <li class="uppercase text-[3rem] md:text-[4rem] leading-none font-teko font-semibold text-secondary my-[10px] py-[10px] transition-colors duration-200 hover:text-white">
          Architecture
        </li>
        <li class="uppercase text-[3rem] md:text-[4rem] leading-none font-teko font-semibold text-secondary my-[10px] py-[10px] transition-colors duration-200 hover:text-white">
          Music video
        </li>
      </ul>
    </Section>

    <Section title="Tech specs">
      <ul class="p-0 m-0 list-none md:flex md:justify-around">
        <li class="flex-1">
          <h3 class="uppercase font-teko text-[#49494b] text-[2rem] md:text-[3rem] lg:text-[4rem]">
            <strong class="text-white block leading-none text-[6rem] sm:text-[7rem] sm:leading-tight md:text-[8rem] lg:text-[10rem] lg:leading-snug xl:text-[12rem]">
              4K/60<span class="text-[5rem]">FPS</span>
            </strong>
            AERIAL VIDEO
          </h3>
        </li>
        <li class="flex-1">
          <h3 class="uppercase font-teko text-[#49494b] text-[2rem] md:text-[3rem] lg:text-[4rem]">
            <strong class="text-white block leading-none text-[6rem] sm:text-[7rem] sm:leading-tight md:text-[8rem] lg:text-[10rem] lg:leading-snug xl:text-[12rem]">
              20<span class="text-[5rem]">MPX</span>
            </strong>
            AERIAL PHOTOGRAPHY
          </h3>
        </li>
        <li class="flex-1">
          <h3 class="uppercase font-teko text-[#49494b] text-[2rem] md:text-[3rem] lg:text-[4rem]">
            <strong class="text-white block leading-none text-[6rem] sm:text-[7rem] sm:leading-tight md:text-[8rem] lg:text-[10rem] lg:leading-snug xl:text-[12rem]">
              162<span class="text-[5rem]">MPX</span>
            </strong>
            360° PHOTOGRAPHY
          </h3>
        </li>
      </ul>
    </Section>

    <Section title="Credentials">
      <div class="text-secondary max-w-[420px] mx-auto">
        <h3 class="text-white text-[4rem] font-semibold font-teko uppercase my-[2em] mt-[25px]">
          ONDŘEJ HÁJEK
        </h3>
        Tel.: <a href="tel:+420773604400" class="no-underline text-secondary">+420 773 604 400</a>
        <br />
        <a href="mailto:info@ondrahajek.com" class="no-underline text-secondary">info@ondrahajek.com</a>
        <br />
        <br />
        <h3 class="text-white text-[4rem] font-semibold font-teko uppercase my-[2em] mt-[25px]">
          COPTER VISION S.R.O.
        </h3>
        držitel povolení k provozování leteckých prací od Úřadu pro civilní letectví
        <br />
        <br />
        ICO: 03803452
        <br />
        DIC: CZ03803452
      </div>
    </Section>
  </Page>
</BaseLayout>
