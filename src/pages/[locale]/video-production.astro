---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Page from '~/components/Page.astro';
import { Header } from '~/components/Header';
import { CategoryPortfolioGrid } from '~/components/CategoryPortfolioGrid';
import { getPortfoliosByCategory, getHeaderBackgroundByPage } from '~/api';
import { localeStaticPaths, getLocaleFromParam, t, CATEGORY_IDS } from '~/i18n';

export function getStaticPaths() {
  return localeStaticPaths();
}

const locale = getLocaleFromParam(Astro.params.locale);
const portfolios = await getPortfoliosByCategory(CATEGORY_IDS['video-production']);
const headerBackground = await getHeaderBackgroundByPage('/');
---

<BaseLayout
  title={`${t(locale, 'category.video.title')} - ${t(locale, 'meta.title')}`}
  description={t(locale, 'category.video.description')}
  locale={locale}
  canonicalPath="/video-production"
>
  <Page locale={locale}>
    <Header
      slot="header"
      client:load
      title={t(locale, 'category.video.title')}
      headerBackground={headerBackground}
      currentPath={`/${locale}/video-production`}
      locale={locale}
      pagePath="/video-production"
    />
    <CategoryPortfolioGrid client:load portfolios={portfolios} locale={locale} />
  </Page>
</BaseLayout>
