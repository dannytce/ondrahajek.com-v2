---
import BaseLayout from '~/layouts/BaseLayout.astro'
import Page from '~/components/Page.astro'
import Header from '~/components/Header.astro'
import FeaturedWork from '~/components/FeaturedWork.astro'
import { getFeaturedPortfolios, getHeaderBackgroundByPage } from '~/api'
import { localeStaticPaths, getLocaleFromParam, t, CATEGORY_IDS } from '~/i18n'

export function getStaticPaths() {
  return localeStaticPaths()
}

const locale = getLocaleFromParam(Astro.params.locale)
const featured = await getFeaturedPortfolios(
  CATEGORY_IDS['selected-work'],
  locale
)
const headerBackground = await getHeaderBackgroundByPage('/')
---

<BaseLayout
  title={t(locale, 'meta.title')}
  description={t(locale, 'meta.description')}
  locale={locale}
  canonicalPath="/"
>
  <Page isHomepage locale={locale}>
    <Header
      slot="header"
      title={t(locale, 'home.title')}
      subTitle={t(locale, 'home.subtitle')}
      homepageHero={{
        brand: t(locale, 'home.heroBrand'),
        line: t(locale, 'home.heroLine'),
        descriptor: t(locale, 'home.heroDescriptor'),
      }}
      headerBackground={headerBackground}
      isHomepage
      currentPath={`/${locale}`}
      locale={locale}
      pagePath="/"
    />
    <FeaturedWork portfolios={featured} locale={locale} />
  </Page>
</BaseLayout>
