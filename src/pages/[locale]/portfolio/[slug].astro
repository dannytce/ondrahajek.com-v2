---
import BaseLayout from '~/layouts/BaseLayout.astro'
import Page from '~/components/Page.astro'
import Player from '~/components/Player.astro'
import PortfolioDescriptions from '~/components/PortfolioDescriptions.astro'
import PortfolioDetailMeta from '~/components/PortfolioDetailMeta.astro'
import { getAllPortfoliosWithSlug, getPortfolioBySlug } from '~/api'
import {
  LOCALES,
  getLocaleFromParam,
  t,
  localePath,
  getCategorySlug,
  getAlternateLocale,
} from '~/i18n'

export async function getStaticPaths() {
  const portfolios = await getAllPortfoliosWithSlug()
  return LOCALES.flatMap((locale) =>
    portfolios.map((p) => ({ params: { locale, slug: p.slug } }))
  )
}

const locale = getLocaleFromParam(Astro.params.locale)
const { slug } = Astro.params
const portfolio = await getPortfolioBySlug(slug as string)

function splitPortfolioTags(raw: string | null | undefined): string[] {
  const str = raw?.trim()
  if (!str) return []
  if (str.includes('#'))
    return str
      .split(/#+/)
      .map((s) => s.trim())
      .filter(Boolean)
  if (str.includes(';'))
    return str
      .split(';')
      .map((s) => s.trim())
      .filter(Boolean)
  return [str]
}

const tagItems = portfolio ? splitPortfolioTags(portfolio.tags) : []

// Determine back link based on primary category
const primaryCategoryId = portfolio?.category?.[0]?.id
const categorySlug = primaryCategoryId
  ? getCategorySlug(primaryCategoryId)
  : null
const backPath =
  categorySlug && categorySlug !== 'selected-work' ? `/${categorySlug}` : '/'
const backLabel =
  categorySlug === 'drone-cinematography'
    ? t(locale, 'nav.drone')
    : categorySlug === 'video-production'
      ? t(locale, 'nav.video')
      : 'Portfolio'
const backLinkText = `${t(locale, 'detail.backTo')} ${backLabel}`

// Locale-aware subtitle
const subtitle =
  locale === 'cs'
    ? portfolio?.subtitleCs || portfolio?.subtitleEn
    : portfolio?.subtitleEn || portfolio?.subtitleCs

const mediaTransitionName = portfolio?.slug
  ? `portfolio-media-${portfolio.slug}`
  : undefined
const altLocale = getAlternateLocale(locale)
const switchUrl = localePath(
  altLocale,
  portfolio ? `/portfolio/${portfolio.slug}` : '/'
)

// Year from date
const year = portfolio?.date ? new Date(portfolio.date).getFullYear() : null

const hasDetailMeta =
  year != null ||
  Boolean(portfolio?.client?.trim()) ||
  Boolean(portfolio?.location?.trim())

// JSON-LD structured data
const jsonLd = portfolio
  ? {
      '@context': 'https://schema.org',
      '@type': 'VideoObject',
      name: portfolio.title,
      description: subtitle ?? portfolio.title,
      thumbnailUrl: portfolio.thumbnail?.responsiveImage?.src,
      uploadDate: portfolio.date ?? undefined,
      embedUrl: portfolio.video ?? undefined,
    }
  : undefined
---

{
  portfolio ? (
    <BaseLayout
      title={`${portfolio.title} - ${t(locale, 'meta.title')}`}
      description={subtitle ?? portfolio.title ?? ''}
      locale={locale}
      compactHeader
      canonicalPath={`/portfolio/${slug}`}
      jsonLd={jsonLd}
    >
      <Page locale={locale}>
        <header
          slot="header"
          class="fixed left-0 right-0 top-0 z-nav border-b border-white/10 bg-background/95 backdrop-blur"
        >
          <div class="mx-auto flex h-20 w-full max-w-container items-center justify-between px-[15px] xl:px-0">
            <a
              href={localePath(locale, '/')}
              class="font-teko text-[1.8rem] uppercase tracking-wide text-white no-underline"
            >
              ONDRAHAJEK.COM
            </a>
            <nav aria-label="Primary" class="flex items-center gap-6">
              <a
                href={localePath(locale, '/drone-cinematography')}
                class="font-teko text-[1.6rem] uppercase text-secondary no-underline transition-colors hover:text-white"
              >
                {t(locale, 'nav.drone')}
              </a>
              <a
                href={localePath(locale, '/video-production')}
                class="font-teko text-[1.6rem] uppercase text-secondary no-underline transition-colors hover:text-white"
              >
                {t(locale, 'nav.video')}
              </a>
              <a
                href={localePath(locale, '/about')}
                class="font-teko text-[1.6rem] uppercase text-secondary no-underline transition-colors hover:text-white"
              >
                {t(locale, 'nav.about')}
              </a>
              <a
                href={switchUrl}
                class="font-teko text-[1.4rem] uppercase text-secondary no-underline transition-colors hover:text-white"
              >
                {t(locale, 'lang.switch')}
              </a>
            </nav>
          </div>
        </header>
        <section class="mx-auto w-full max-w-container px-[15px] pb-16 pt-[10.5rem] xl:px-0">
          <a
            href={localePath(locale, backPath)}
            class="detail-reveal mb-8 inline-block font-teko text-[2rem] uppercase text-secondary no-underline transition-colors hover:text-white"
          >
            {backLinkText}
          </a>

          <div
            class:list={[
              'grid gap-10',
              hasDetailMeta && 'xl:grid-cols-[minmax(0,1fr)_300px]',
            ]}
          >
            <div>
              <h1 class="detail-reveal m-0 font-teko text-[5.2rem] uppercase leading-[0.95] tracking-[0.01em] text-white md:text-[7.2rem]">
                {portfolio.title}
              </h1>
              {(subtitle || hasDetailMeta) && (
                <div class="detail-reveal detail-reveal-delay-1 mt-4 max-w-[70ch] xl:hidden">
                  <PortfolioDetailMeta
                    variant="inline"
                    locale={locale}
                    year={year}
                    client={portfolio.client}
                    location={portfolio.location}
                    class={subtitle ? 'mt-4' : undefined}
                  />
                </div>
              )}
              {portfolio.video && (
                <div class="detail-reveal detail-reveal-delay-1 mt-8">
                  <Player
                    title={portfolio.title ?? 'Video'}
                    video={portfolio.video}
                    poster={portfolio.thumbnail?.responsiveImage}
                    transitionName={mediaTransitionName}
                  />
                </div>
              )}
              <div class="detail-reveal detail-reveal-delay-2">
                <PortfolioDescriptions
                  descriptionCs={portfolio.descriptionCs}
                  descriptionEn={portfolio.descriptionEn}
                  locale={locale}
                />
              </div>
              {tagItems.length > 0 && (
                <ul class="detail-reveal detail-reveal-delay-3 m-0 mt-8 flex max-w-[70ch] list-none flex-wrap gap-2 p-0">
                  {tagItems.map((tag) => (
                    <li class="rounded-sm border border-secondary/40 px-3 py-1 font-teko text-[1.5rem] uppercase tracking-wide text-secondary">
                      {tag.includes('-') && !tag.includes(' ')
                        ? tag.replace(/-/g, ' ')
                        : tag}
                    </li>
                  ))}
                </ul>
              )}
            </div>
            {hasDetailMeta && (
              <aside class="detail-reveal detail-reveal-delay-1 hidden h-fit rounded border border-white/10 bg-[#111114] p-6 xl:sticky xl:top-28 xl:block">
                <PortfolioDetailMeta
                  locale={locale}
                  year={year}
                  client={portfolio.client}
                  location={portfolio.location}
                />
              </aside>
            )}
          </div>
        </section>
      </Page>
    </BaseLayout>
  ) : (
    <BaseLayout
      title={`Not found - ${t(locale, 'meta.title')}`}
      locale={locale}
      compactHeader
    >
      <Page locale={locale}>
        <header
          slot="header"
          class="fixed left-0 right-0 top-0 z-nav border-b border-white/10 bg-background/95 backdrop-blur"
        >
          <div class="mx-auto flex h-20 w-full max-w-container items-center px-[15px] xl:px-0">
            <a
              href={localePath(locale, '/')}
              class="font-teko text-[1.8rem] uppercase tracking-wide text-white no-underline"
            >
              ONDRAHAJEK.COM
            </a>
          </div>
        </header>
        <section class="mx-auto w-full max-w-container px-[15px] pb-16 pt-[10.5rem] text-center xl:px-0">
          <p class="text-[2rem] text-secondary">
            This portfolio item could not be found.
          </p>
          <a
            href={localePath(locale, '/')}
            class="mt-4 inline-block font-teko text-[2rem] uppercase text-white no-underline hover:opacity-80"
          >
            {t(locale, 'detail.back')}
          </a>
        </section>
      </Page>
    </BaseLayout>
  )
}
