---
import BaseLayout from '~/layouts/BaseLayout.astro'
import Page from '~/components/Page.astro'
import PortfolioDetailNav from '~/components/portfolio/PortfolioDetailNav.astro'
import PortfolioDetailView from '~/components/portfolio/PortfolioDetailView.astro'
import PortfolioNotFound from '~/components/portfolio/PortfolioNotFound.astro'
import {
  getAllPortfoliosWithSlug,
  getPortfolioBySlug,
  getPortfoliosByCategory,
} from '~/api'
import { LOCALES, getLocaleFromParam } from '~/i18n'
import { portfolioSegment } from '~/i18n/routes'
import {
  buildPortfolioDetailModel,
  portfolioDetailCanonicalPath,
} from '~/lib/portfolio-detail/buildPortfolioDetail'
import { portfolioSlugForLocale } from '~/lib/portfolio-slug-locale'

export async function getStaticPaths() {
  const portfolios = await getAllPortfoliosWithSlug()
  return LOCALES.flatMap((locale) =>
    portfolios.flatMap((p) => {
      const slug = portfolioSlugForLocale(p, locale)
      if (!slug) return []
      return [
        {
          params: {
            locale,
            portfolioSeg: portfolioSegment(locale),
            slug,
          },
        },
      ]
    })
  )
}

const locale = getLocaleFromParam(Astro.params.locale)
const { slug } = Astro.params

const requestedSlug = (slug ?? '').trim()

let portfolio = requestedSlug
  ? await getPortfolioBySlug(requestedSlug, locale)
  : null

if (!portfolio && requestedSlug) {
  const slugPairs = await getAllPortfoliosWithSlug()
  const matched = slugPairs.find(
    (p) => p.slugEn?.trim() === requestedSlug || p.slugCs?.trim() === requestedSlug
  )
  const localizedSlug = matched ? portfolioSlugForLocale(matched, locale) : null
  const lookupSlug = matched?.slugEn?.trim() || matched?.slugCs?.trim() || null

  if (lookupSlug) {
    portfolio = await getPortfolioBySlug(lookupSlug, locale)
  }

  if (localizedSlug && localizedSlug !== requestedSlug) {
    return Astro.redirect(
      `/${locale}${portfolioDetailCanonicalPath(locale, localizedSlug)}`,
      302
    )
  }
}

const detail = portfolio
  ? await buildPortfolioDetailModel(portfolio, locale, getPortfoliosByCategory)
  : null
---

{
  portfolio && detail ? (
    <BaseLayout
      title={detail.titleSeo}
      description={detail.descSeo}
      locale={locale}
      canonicalPath={portfolioDetailCanonicalPath(locale, slug as string)}
      hreflangPaths={detail.hrefPair}
      jsonLd={detail.jsonLd}
    >
      <Page locale={locale}>
        <PortfolioDetailNav
          slot="header"
          locale={locale}
          switchUrl={detail.switchUrl}
        />
        <PortfolioDetailView portfolio={portfolio} locale={locale} detail={detail} />
      </Page>
    </BaseLayout>
  ) : (
    <PortfolioNotFound locale={locale} />
  )
}
