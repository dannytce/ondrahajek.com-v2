
---
import BaseLayout from '~/layouts/BaseLayout.astro'
import Page from '~/components/Page.astro'
import PortfolioDetailNav from '~/components/portfolio/PortfolioDetailNav.astro'
import PortfolioDetailView from '~/components/portfolio/PortfolioDetailView.astro'
import PortfolioNotFound from '~/components/portfolio/PortfolioNotFound.astro'
import {
  getAllPortfoliosWithSlug,
  getPortfolioBySlug,
  getPortfoliosByCategory,
} from '~/api'
import { LOCALES, getLocaleFromParam } from '~/i18n'
import { portfolioSegment } from '~/i18n/routes'
import {
  buildPortfolioDetailModel,
  portfolioDetailCanonicalPath,
} from '~/lib/portfolio-detail/buildPortfolioDetail'

export async function getStaticPaths() {
  const portfolios = await getAllPortfoliosWithSlug()
  return LOCALES.flatMap((locale) =>
    portfolios.map((p) => ({
      params: {
        locale,
        portfolioSeg: portfolioSegment(locale),
        slug: p.slug,
      },
    }))
  )
}

const locale = getLocaleFromParam(Astro.params.locale)
const { slug } = Astro.params

const portfolio = await getPortfolioBySlug(slug as string, locale)
const detail = portfolio
  ? await buildPortfolioDetailModel(
      portfolio,
      locale,
      slug as string,
      getPortfoliosByCategory
    )
  : null
---

{
  portfolio && detail ? (
    <BaseLayout
      title={detail.titleSeo}
      description={detail.descSeo}
      locale={locale}
      compactHeader
      canonicalPath={portfolioDetailCanonicalPath(locale, slug as string)}
      hreflangPaths={detail.hrefPair}
      jsonLd={detail.jsonLd}
    >
      <Page locale={locale}>
        <PortfolioDetailNav
          slot="header"
          locale={locale}
          switchUrl={detail.switchUrl}
        />
        <PortfolioDetailView portfolio={portfolio} locale={locale} detail={detail} />
      </Page>
    </BaseLayout>
  ) : (
    <PortfolioNotFound locale={locale} />
  )
}
