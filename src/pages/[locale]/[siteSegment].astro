---
import SiteGalleryPage from '~/components/site/SiteGalleryPage.astro'
import SiteAboutPage from '~/components/site/SiteAboutPage.astro'
import SiteCategoryHubPage from '~/components/site/SiteCategoryHubPage.astro'
import {
  getPortfoliosByCategory,
  getHeaderBackgroundByPage,
  getGallery,
} from '~/api'
import { LOCALES, getLocaleFromParam, CATEGORY_IDS } from '~/i18n'
import {
  localizedPagePath,
  sitePageKeyFromSegment,
  hreflangPairForSitePage,
  languageSwitchHref,
  type SitePageKey,
} from '~/i18n/routes'
import {
  buildCategoryCollectionJsonLd,
  categoryHubSeo,
} from '~/lib/site-segment'

export function getStaticPaths() {
  const keys: SitePageKey[] = ['drone', 'video', 'gallery', 'about']
  return LOCALES.flatMap((locale) =>
    keys.map((key) => ({
      params: {
        locale,
        siteSegment: localizedPagePath(locale, key).slice(1),
      },
    }))
  )
}

const locale = getLocaleFromParam(Astro.params.locale)
const { siteSegment } = Astro.params
const pageKey = sitePageKeyFromSegment(locale, siteSegment as string)

if (!pageKey) {
  return new Response(null, { status: 404 })
}

const href = hreflangPairForSitePage(pageKey)
const switchHref = languageSwitchHref(locale, pageKey)
const canonicalPath = localizedPagePath(locale, pageKey)

const photos = pageKey === 'gallery' ? await getGallery() : null
const headerBackgroundGallery =
  pageKey === 'gallery' ? await getHeaderBackgroundByPage('/gallery') : null
const headerBackgroundAbout =
  pageKey === 'about' ? await getHeaderBackgroundByPage('/about') : null
const headerBackgroundCategory =
  pageKey === 'drone' || pageKey === 'video'
    ? await getHeaderBackgroundByPage('/')
    : null

const categorySlug: 'drone-cinematography' | 'video-production' | null =
  pageKey === 'drone'
    ? 'drone-cinematography'
    : pageKey === 'video'
      ? 'video-production'
      : null

const portfolios =
  categorySlug != null
    ? await getPortfoliosByCategory(CATEGORY_IDS[categorySlug], locale)
    : null

const hubSeo =
  pageKey === 'drone' || pageKey === 'video'
    ? categoryHubSeo(locale, pageKey)
    : null

const collectionJsonLd =
  portfolios &&
  categorySlug &&
  hubSeo &&
  (pageKey === 'drone' || pageKey === 'video')
    ? buildCategoryCollectionJsonLd(
        locale,
        pageKey,
        portfolios,
        canonicalPath,
        hubSeo.defaultSeoDescription
      )
    : undefined
---

{
  pageKey === 'gallery' && photos && headerBackgroundGallery && (
    <SiteGalleryPage
      locale={locale}
      canonicalPath={canonicalPath}
      hreflangPaths={href}
      switchHref={switchHref}
      photos={photos}
      headerBackground={headerBackgroundGallery}
    />
  )
}

{
  pageKey === 'about' && headerBackgroundAbout && (
    <SiteAboutPage
      locale={locale}
      canonicalPath={canonicalPath}
      hreflangPaths={href}
      switchHref={switchHref}
      headerBackground={headerBackgroundAbout}
    />
  )
}

{
  (pageKey === 'drone' || pageKey === 'video') &&
    portfolios &&
    categorySlug &&
    headerBackgroundCategory &&
    collectionJsonLd &&
    hubSeo && (
      <SiteCategoryHubPage
        locale={locale}
        canonicalPath={canonicalPath}
        hreflangPaths={href}
        switchHref={switchHref}
        categorySlug={categorySlug}
        portfolios={portfolios}
        headerBackground={headerBackgroundCategory}
        defaultSeoTitle={hubSeo.defaultSeoTitle}
        defaultSeoDescription={hubSeo.defaultSeoDescription}
        categoryTitle={hubSeo.categoryTitle}
        collectionJsonLd={collectionJsonLd}
      />
    )
}
