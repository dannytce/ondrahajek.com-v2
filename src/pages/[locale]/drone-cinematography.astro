---
import BaseLayout from '~/layouts/BaseLayout.astro'
import Page from '~/components/Page.astro'
import Header from '~/components/Header.astro'
import CategoryPortfolioGrid from '~/components/CategoryPortfolioGrid.astro'
import { getPortfoliosByCategory, getHeaderBackgroundByPage } from '~/api'
import { localeStaticPaths, getLocaleFromParam, t, CATEGORY_IDS } from '~/i18n'

export function getStaticPaths() {
  return localeStaticPaths()
}

const siteUrl = 'https://ondrahajek.com'
const locale = getLocaleFromParam(Astro.params.locale)
const portfolios = await getPortfoliosByCategory(
  CATEGORY_IDS['drone-cinematography']
)
const headerBackground = await getHeaderBackgroundByPage('/')

const defaultSeoTitle = `${t(locale, 'category.drone.title')} - ${t(locale, 'meta.title')}`
const defaultSeoDescription = t(locale, 'category.drone.description')

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: t(locale, 'category.drone.title'),
  description: defaultSeoDescription,
  url: `${siteUrl}/${locale}/drone-cinematography`,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: portfolios.filter((p) => p.slug).length,
    itemListElement: portfolios
      .filter((p) => p.slug)
      .map((p, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `${siteUrl}/${locale}/portfolio/${p.slug}`,
        name: p.title ?? undefined,
      })),
  },
}
---

<BaseLayout
  title={defaultSeoTitle}
  description={defaultSeoDescription}
  locale={locale}
  canonicalPath="/drone-cinematography"
  jsonLd={collectionJsonLd}
>
  <Page locale={locale}>
    <Header
      slot="header"
      title={t(locale, 'category.drone.title')}
      headerBackground={headerBackground}
      currentPath={`/${locale}/drone-cinematography`}
      locale={locale}
      pagePath="/drone-cinematography"
    />
    <CategoryPortfolioGrid
      portfolios={portfolios}
      locale={locale}
      categorySlug="drone-cinematography"
      defaultSeoTitle={defaultSeoTitle}
      defaultSeoDescription={defaultSeoDescription}
    />
  </Page>
</BaseLayout>
