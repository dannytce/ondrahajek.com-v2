---
// Redirect old /gallery → /en/gallery
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content="0;url=/en/gallery" />
    <link rel="canonical" href="/en/gallery" />
    <title>Redirecting...</title>
  </head>
  <body>
    <script is:inline>
      window.location.replace('/en/gallery')
    </script>
    <noscript><a href="/en/gallery">Click here</a></noscript>
  </body>
</html>
