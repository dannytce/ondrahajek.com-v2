---
import Player from '~/components/Player.astro'
import PortfolioDescriptions from '~/components/PortfolioDescriptions.astro'
import PortfolioDetailMeta from '~/components/PortfolioDetailMeta.astro'
import type { PortfolioDetail } from '~/api'
import type { PortfolioDetailModel } from '~/lib/portfolio-detail/buildPortfolioDetail'
import { localePath, type Locale } from '~/i18n'
import { localizedPagePath } from '~/i18n/routes'

interface Props {
  portfolio: PortfolioDetail
  locale: Locale
  detail: PortfolioDetailModel
}

const { portfolio, locale, detail } = Astro.props
const {
  tagLinkPairs,
  pageKey,
  backPath,
  backLinkText,
  moreForClientHref,
  moreInLocationHref,
  moreForClientLabel,
  moreInLocationLabel,
  subtitle,
  mediaTransitionName,
  year,
  hasDetailMeta,
  locationH2,
} = detail
---

<section class="mx-auto w-full max-w-container px-5 pb-14 pt-[7.8rem] md:pb-16 xl:px-0">
  <a
    href={localePath(locale, backPath)}
    class="detail-reveal mb-5 inline-block font-geist text-[1rem] uppercase tracking-[0.2em] text-[#888888] no-underline transition-colors hover:text-white"
  >
    {backLinkText}
  </a>

  {
    portfolio.video && (
      <div class="detail-reveal detail-reveal-delay-1 mb-8 hidden overflow-hidden rounded-xl lg:block">
        <Player
          title={portfolio.title ?? 'Video'}
          video={portfolio.video}
          poster={portfolio.thumbnail?.responsiveImage}
          transitionName={mediaTransitionName}
        />
      </div>
    )
  }

  <div class:list={['hidden gap-16 lg:grid', hasDetailMeta && 'lg:grid-cols-[minmax(0,1fr)_320px]']}>
    <div class="min-w-0">
      <h1
        class="detail-reveal m-0 font-anton text-[4.2rem] uppercase leading-[0.92] tracking-[0.01em] text-white xl:text-[4.8rem]"
      >
        {portfolio.title}
      </h1>
      {
        locationH2 && (
          <h2 class="detail-reveal mt-4 max-w-[70ch] font-geist text-[1rem] font-normal uppercase leading-tight tracking-[0.2em] text-[#4A9FD8]">
            {locationH2}
          </h2>
        )
      }
      <div class="detail-reveal detail-reveal-delay-2 mt-6 max-w-[72ch]">
        <PortfolioDescriptions
          descriptionCs={portfolio.descriptionCs}
          descriptionEn={portfolio.descriptionEn}
          locale={locale}
        />
      </div>
      {
        tagLinkPairs.length > 0 && (
          <ul class="detail-reveal detail-reveal-delay-3 m-0 mt-8 flex max-w-[70ch] list-none flex-wrap gap-2 p-0">
            {tagLinkPairs.map(({ key, label }) => (
              <li>
                {pageKey != null ? (
                  <a
                    href={localePath(
                      locale,
                      `${localizedPagePath(locale, pageKey)}?tag=${encodeURIComponent(key)}`
                    )}
                    class="inline-block rounded-full border border-white/20 bg-white/5 px-3 py-1 font-geist text-[1rem] uppercase tracking-[0.12em] text-[#B7B7B7] no-underline transition-colors hover:border-white/30 hover:text-white"
                  >
                    {label}
                  </a>
                ) : (
                  <span class="inline-block rounded-full border border-white/20 bg-white/5 px-3 py-1 font-geist text-[1rem] uppercase tracking-[0.12em] text-[#B7B7B7]">
                    {label}
                  </span>
                )}
              </li>
            ))}
          </ul>
        )
      }
    </div>
    {hasDetailMeta && (
      <aside class="detail-reveal detail-reveal-delay-1 h-fit rounded-xl border border-white/10 bg-[#141414] p-6 lg:sticky lg:top-24">
        <PortfolioDetailMeta
          locale={locale}
          year={year}
          client={portfolio.client}
          location={portfolio.location}
          moreForClientHref={moreForClientHref}
          moreForClientLabel={moreForClientLabel}
          moreInLocationHref={moreInLocationHref}
          moreInLocationLabel={moreInLocationLabel}
        />
      </aside>
    )}
  </div>

  <div class="lg:hidden">
    <div>
      <h1
        class="detail-reveal m-0 font-anton text-[3.8rem] uppercase leading-[0.92] tracking-[0.01em] text-white md:text-[7.2rem]"
      >
        {portfolio.title}
      </h1>
      {
        locationH2 && (
          <h2 class="detail-reveal mt-3 max-w-[70ch] font-geist text-[1rem] font-normal uppercase leading-tight tracking-[0.2em] text-[#4A9FD8] md:text-[1.1rem]">
            {locationH2}
          </h2>
        )
      }
      {
        (subtitle || hasDetailMeta) && (
          <div class="detail-reveal detail-reveal-delay-1 mt-4 max-w-[70ch]">
            <PortfolioDetailMeta
              variant="inline"
              locale={locale}
              year={year}
              client={portfolio.client}
              location={portfolio.location}
              class={subtitle ? 'mt-4' : undefined}
              moreForClientHref={moreForClientHref}
              moreForClientLabel={moreForClientLabel}
              moreInLocationHref={moreInLocationHref}
              moreInLocationLabel={moreInLocationLabel}
            />
          </div>
        )
      }
      {
        portfolio.video && (
          <div class="detail-reveal detail-reveal-delay-1 mt-6 overflow-hidden rounded-lg">
            <Player
              title={portfolio.title ?? 'Video'}
              video={portfolio.video}
              poster={portfolio.thumbnail?.responsiveImage}
              transitionName={mediaTransitionName}
            />
          </div>
        )
      }
      <div class="detail-reveal detail-reveal-delay-2">
        <PortfolioDescriptions
          descriptionCs={portfolio.descriptionCs}
          descriptionEn={portfolio.descriptionEn}
          locale={locale}
        />
      </div>
      {
        tagLinkPairs.length > 0 && (
          <ul class="detail-reveal detail-reveal-delay-3 m-0 mt-8 flex max-w-[70ch] list-none flex-wrap gap-2 p-0">
            {tagLinkPairs.map(({ key, label }) => (
              <li>
                {pageKey != null ? (
                  <a
                    href={localePath(
                      locale,
                      `${localizedPagePath(locale, pageKey)}?tag=${encodeURIComponent(key)}`
                    )}
                    class="inline-block rounded-full border border-white/20 bg-white/5 px-3 py-1 font-geist text-[1rem] uppercase tracking-[0.12em] text-[#B7B7B7] no-underline transition-colors hover:border-white/30 hover:text-white"
                  >
                    {label}
                  </a>
                ) : (
                  <span class="inline-block rounded-full border border-white/20 bg-white/5 px-3 py-1 font-geist text-[1rem] uppercase tracking-[0.12em] text-[#B7B7B7]">
                    {label}
                  </span>
                )}
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>
</section>
