---
import Player from '~/components/Player.astro'
import PortfolioDescriptions from '~/components/PortfolioDescriptions.astro'
import PortfolioDetailMeta from '~/components/PortfolioDetailMeta.astro'
import ActionButton from '~/components/ActionButton.astro'
import type { PortfolioDetail } from '~/api'
import { CONTACT_EMAIL } from '~/config'
import type { PortfolioDetailModel } from '~/lib/portfolio-detail/buildPortfolioDetail'
import { localePath, t, type Locale } from '~/i18n'
import { localizedPagePath, type SitePageKey } from '~/i18n/routes'

interface Props {
  portfolio: PortfolioDetail
  locale: Locale
  detail: PortfolioDetailModel
}

const { portfolio, locale, detail } = Astro.props
const {
  tagLinkPairs,
  pageKey,
  backPath,
  backLinkText,
  moreForClientHref,
  moreInLocationHref,
  moreForClientLabel,
  moreInLocationLabel,
  subtitle,
  mediaTransitionName,
  year,
  hasDetailMeta,
  heroSubtitle,
} = detail
const categoryNavLabelKeyByPageKey: Partial<
  Record<SitePageKey, 'nav.drone' | 'nav.video'>
> = {
  drone: 'nav.drone',
  video: 'nav.video',
}
function getCategoryLabel(pageKey: string): string | undefined {
  const categoryLabelKey =
    categoryNavLabelKeyByPageKey[pageKey as SitePageKey]
  return categoryLabelKey ? t(locale, categoryLabelKey) : undefined
}
---

<section class="mx-auto w-full max-w-container px-5 pb-14 pt-[7.8rem] md:pb-16 xl:px-0">
  <a
    href={localePath(locale, backPath)}
    class="detail-reveal mb-5 inline-block font-geist text-[1rem] uppercase tracking-[0.2em] text-[#888888] no-underline transition-colors hover:text-white"
  >
    {backLinkText}
  </a>

  <div class:list={['grid gap-10 lg:gap-16', hasDetailMeta && 'lg:grid-cols-[minmax(0,1fr)_320px]']}>
    <div class="min-w-0">
      <h1
        class="detail-reveal m-0 font-anton text-[3.8rem] uppercase leading-[0.92] tracking-[0.01em] text-white md:text-[7.2rem] lg:text-[4.2rem] xl:text-[4.8rem]"
      >
        {portfolio.title}
      </h1>
      {
        heroSubtitle && (
          <h2 class="detail-reveal mt-3 max-w-[70ch] font-geist text-[1rem] font-normal uppercase leading-tight tracking-[0.2em] text-[#4A9FD8] md:text-[1.1rem] lg:mt-4 lg:text-[1rem]">
            {heroSubtitle}
          </h2>
        )
      }
      {
        (subtitle || hasDetailMeta) && (
          <div class="detail-reveal detail-reveal-delay-1 mt-4 max-w-[70ch] lg:hidden">
            <PortfolioDetailMeta
              variant="inline"
              locale={locale}
              year={year}
              client={portfolio.client}
              location={portfolio.location}
              class={subtitle ? 'mt-4' : undefined}
              moreForClientHref={moreForClientHref}
              moreForClientLabel={moreForClientLabel}
              moreInLocationHref={moreInLocationHref}
              moreInLocationLabel={moreInLocationLabel}
            />
          </div>
        )
      }
      {
        portfolio.video && (
          <div class="detail-reveal detail-reveal-delay-1 mt-6 overflow-hidden rounded-lg lg:mt-8 lg:rounded-xl">
            <Player
              title={portfolio.title ?? t(locale, 'detail.videoTitleFallback')}
              video={portfolio.video}
              poster={portfolio.thumbnail?.responsiveImage}
              transitionName={mediaTransitionName}
            />
          </div>
        )
      }
      <div class="detail-reveal detail-reveal-delay-2 mt-6">
        <PortfolioDescriptions
          descriptionCs={portfolio.descriptionCs}
          descriptionEn={portfolio.descriptionEn}
          locale={locale}
        />
      </div>
      {
        tagLinkPairs.length > 0 && (
          <ul class="detail-reveal detail-reveal-delay-3 m-0 mt-8 flex max-w-[70ch] list-none flex-wrap gap-2 p-0">
            {tagLinkPairs.map(({ key, label }) => (
              <li>
                {pageKey != null ? (
                  <a
                    href={localePath(
                      locale,
                      `${localizedPagePath(locale, pageKey)}?tag=${encodeURIComponent(key)}`
                    )}
                    class="inline-block rounded-full border border-white/20 bg-white/5 px-3 py-1 font-geist text-[1rem] uppercase tracking-[0.12em] text-[#B7B7B7] no-underline transition-colors hover:border-white/30 hover:text-white"
                  >
                    {label}
                  </a>
                ) : (
                  <span class="inline-block rounded-full border border-white/20 bg-white/5 px-3 py-1 font-geist text-[1rem] uppercase tracking-[0.12em] text-[#B7B7B7]">
                    {label}
                  </span>
                )}
              </li>
            ))}
          </ul>
        )
      }
    </div>
    {hasDetailMeta && (
      <aside class="detail-reveal detail-reveal-delay-1 h-fit lg:sticky lg:top-24">
        <PortfolioDetailMeta
          locale={locale}
          year={year}
          client={portfolio.client}
          location={portfolio.location}
          categoryLabel={pageKey ? getCategoryLabel(pageKey) : undefined}
          moreForClientHref={moreForClientHref}
          moreForClientLabel={moreForClientLabel}
          moreInLocationHref={moreInLocationHref}
          moreInLocationLabel={moreInLocationLabel}
        />
        <div class="mt-3 grid grid-cols-2 gap-3">
          <ActionButton label={t(locale, 'detail.share')} type="button" variant="secondary">
            <svg
              slot="icon"
              aria-hidden="true"
              viewBox="0 0 24 24"
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="18" cy="5" r="2.5"></circle>
              <circle cx="6" cy="12" r="2.5"></circle>
              <circle cx="18" cy="19" r="2.5"></circle>
              <path d="M8.2 10.9l7.6-4.3"></path>
              <path d="M8.2 13.1l7.6 4.3"></path>
            </svg>
          </ActionButton>
          <ActionButton
            href={`mailto:${CONTACT_EMAIL}`}
            label={t(locale, 'detail.getInTouch')}
            variant="primary"
          />
        </div>
      </aside>
    )}
  </div>
</section>
