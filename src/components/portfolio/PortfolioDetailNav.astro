---
import LanguageToggle from '~/components/LanguageToggle.astro'
import NavDesktopLinkLabel from '~/components/NavDesktopLinkLabel.astro'
import { t, localePath, type Locale } from '~/i18n'
import { localizedPagePath } from '~/i18n/routes'

interface Props {
  locale: Locale
  switchUrl: string
  /** When true, only logo (404 and similar). */
  minimal?: boolean
}

const { locale, switchUrl, minimal = false } = Astro.props
const navLinks = [
  {
    text: t(locale, 'nav.drone'),
    link: localePath(locale, localizedPagePath(locale, 'drone')),
  },
  {
    text: t(locale, 'nav.video'),
    link: localePath(locale, localizedPagePath(locale, 'video')),
  },
  {
    text: t(locale, 'nav.gallery'),
    link: localePath(locale, localizedPagePath(locale, 'gallery')),
  },
  {
    text: t(locale, 'nav.about'),
    link: localePath(locale, localizedPagePath(locale, 'about')),
  },
]
---

<header
  slot="header"
  class="fixed left-0 right-0 top-0 z-nav border-b border-white/10 bg-[#0A0A0A]/90 backdrop-blur-md"
>
  <div
    class:list={[
      'mx-auto flex h-[64px] w-full max-w-container items-center px-5 xl:px-0',
      !minimal && 'justify-between',
    ]}
  >
    <div class="hidden items-center gap-12 md:flex">
      <a
        href={localePath(locale, '/')}
        class="flex items-center font-anton text-[1.3rem] tracking-[0.08em] text-white no-underline"
      >
        ONDRAHAJEK.COM
      </a>
      {
        !minimal && (
          <div class="flex items-center gap-8">
            {navLinks.map((item, index) => (
              <a
                href={item.link}
                class="font-inter text-[1.3rem] text-[#888888] no-underline transition-colors hover:text-white"
              >
                <NavDesktopLinkLabel
                  locale={locale}
                  index={index}
                  fallback={item.text}
                />
              </a>
            ))}
          </div>
        )
      }
    </div>
    <a
      href={localePath(locale, '/')}
      class="flex items-center font-anton text-[1.3rem] tracking-[0.08em] text-white no-underline md:hidden"
    >
      ONDRAHAJEK.COM
    </a>
    {
      !minimal && (
        <nav aria-label="Primary" class="flex items-center gap-6">
          <LanguageToggle locale={locale} switchUrl={switchUrl} />
        </nav>
      )
    }
  </div>
</header>
