---
import LanguageToggle from '~/components/LanguageToggle.astro'
import { t, localePath, type Locale } from '~/i18n'
import { localizedPagePath } from '~/i18n/routes'

interface Props {
  locale: Locale
  switchUrl: string
  /** When true, only logo (404 and similar). */
  minimal?: boolean
}

const { locale, switchUrl, minimal = false } = Astro.props
---

<header
  slot="header"
  class="fixed left-0 right-0 top-0 z-nav border-b border-white/5 bg-surface-dark/90 backdrop-blur-md"
>
  <div
    class:list={[
      'mx-auto flex h-20 w-full max-w-container items-center px-[15px] xl:px-0',
      !minimal && 'justify-between',
    ]}
  >
    <a
      href={localePath(locale, '/')}
      class="flex items-center"
    >
      <img src="/logo-ondrahajek.svg" alt="ONDRAHAJEK.COM" class="h-5" />
    </a>
    {
      !minimal && (
        <nav aria-label="Primary" class="flex items-center gap-6">
          <a
            href={localePath(locale, localizedPagePath(locale, 'drone'))}
            class="hidden font-inter text-[1.3rem] uppercase tracking-wider text-foreground-muted no-underline transition-colors hover:text-white md:block"
          >
            {t(locale, 'nav.drone')}
          </a>
          <a
            href={localePath(locale, localizedPagePath(locale, 'video'))}
            class="hidden font-inter text-[1.3rem] uppercase tracking-wider text-foreground-muted no-underline transition-colors hover:text-white md:block"
          >
            {t(locale, 'nav.video')}
          </a>
          <a
            href={localePath(locale, localizedPagePath(locale, 'about'))}
            class="hidden font-inter text-[1.3rem] uppercase tracking-wider text-foreground-muted no-underline transition-colors hover:text-white md:block"
          >
            {t(locale, 'nav.about')}
          </a>
          <LanguageToggle locale={locale} switchUrl={switchUrl} />
        </nav>
      )
    }
  </div>
</header>
