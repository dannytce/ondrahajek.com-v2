---
import LanguageToggle from '~/components/LanguageToggle.astro'
import { t, localePath, type Locale } from '~/i18n'
import { localizedPagePath } from '~/i18n/routes'

interface Props {
  locale: Locale
  switchUrl: string
  /** When true, only logo (404 and similar). */
  minimal?: boolean
}

const { locale, switchUrl, minimal = false } = Astro.props
---

<header
  slot="header"
  class="fixed left-0 right-0 top-0 z-nav border-b border-white/10 bg-[#0A0A0A]/90 backdrop-blur-md"
>
  <div
    class:list={[
      'mx-auto flex h-[64px] w-full max-w-container items-center px-5 xl:px-0',
      !minimal && 'justify-between',
    ]}
  >
    <a
      href={localePath(locale, '/')}
      class="font-anton text-[1.3rem] tracking-[0.08em] text-white no-underline"
    >
      ONDRAHAJEK.COM
    </a>
    {
      !minimal && (
        <nav aria-label="Primary" class="flex items-center gap-6">
          <a
            href={localePath(locale, localizedPagePath(locale, 'drone'))}
            class="hidden font-geist text-[1.1rem] uppercase tracking-[0.2em] text-[#BBBBBB] no-underline transition-colors hover:text-white md:block"
          >
            {t(locale, 'nav.drone')}
          </a>
          <a
            href={localePath(locale, localizedPagePath(locale, 'video'))}
            class="hidden font-geist text-[1.1rem] uppercase tracking-[0.2em] text-[#BBBBBB] no-underline transition-colors hover:text-white md:block"
          >
            {t(locale, 'nav.video')}
          </a>
          <a
            href={localePath(locale, localizedPagePath(locale, 'about'))}
            class="hidden font-geist text-[1.1rem] uppercase tracking-[0.2em] text-[#BBBBBB] no-underline transition-colors hover:text-white md:block"
          >
            {t(locale, 'nav.about')}
          </a>
          <LanguageToggle locale={locale} switchUrl={switchUrl} />
        </nav>
      )
    }
  </div>
</header>
