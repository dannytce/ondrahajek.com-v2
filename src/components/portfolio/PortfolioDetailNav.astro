---
import HeaderNav from '~/components/header/HeaderNav.astro'
import { type Locale } from '~/i18n'
import { getNavLinks } from '~/lib/navigation'

interface Props {
  locale: Locale
  switchUrl: string
  /** When true, only logo (404 and similar). */
  minimal?: boolean
}

const { locale, switchUrl, minimal = false } = Astro.props
const navLinks = minimal ? [] : getNavLinks(locale)
---

<HeaderNav
  locale={locale}
  currentPath=""
  switchUrl={switchUrl}
  navLinks={navLinks}
/>

<script>
  import '~/scripts/header.ts'
</script>

