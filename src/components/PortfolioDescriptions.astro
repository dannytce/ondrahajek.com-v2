---
import { StructuredText } from '@datocms/astro'
import type { CdaStructuredTextValue } from 'datocms-structured-text-utils'
import type { Locale } from '~/i18n'

interface Props {
  descriptionCs?: CdaStructuredTextValue | null
  descriptionEn?: CdaStructuredTextValue | null
  locale?: Locale
}

const { descriptionCs, descriptionEn, locale = 'en' } = Astro.props

const hasCs = descriptionCs?.value != null
const hasEn = descriptionEn?.value != null
const primary =
  locale === 'cs'
    ? { data: descriptionCs ?? descriptionEn, has: hasCs || hasEn }
    : { data: descriptionEn ?? descriptionCs, has: hasEn || hasCs }
---

{
  (hasCs || hasEn) && (
    <div
      class="mt-10 space-y-8 font-sans text-[1.25rem] leading-relaxed text-white/90 md:text-[1.35rem] lg:text-[2rem]"
      data-portfolio-descriptions
    >
      {primary.has && primary.data && (
        <section>
          <div class="[&_a]:text-secondary [&_a]:underline [&_p]:mb-3">
            <StructuredText data={primary.data} />
          </div>
        </section>
      )}
    </div>
  )
}
