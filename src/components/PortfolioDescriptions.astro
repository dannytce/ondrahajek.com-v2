---
import { StructuredText } from '@datocms/astro'
import type { CdaStructuredTextValue } from 'datocms-structured-text-utils'
import type { Locale } from '~/i18n'

interface Props {
  descriptionCs?: CdaStructuredTextValue | null
  descriptionEn?: CdaStructuredTextValue | null
  locale?: Locale
}

const { descriptionCs, descriptionEn, locale = 'en' } = Astro.props

const hasCs = descriptionCs?.value != null
const hasEn = descriptionEn?.value != null
const primary =
  locale === 'cs'
    ? { data: descriptionCs, label: 'Čeština', has: hasCs }
    : { data: descriptionEn, label: 'English', has: hasEn }
const secondary =
  locale === 'cs'
    ? { data: descriptionEn, label: 'English', has: hasEn }
    : { data: descriptionCs, label: 'Čeština', has: hasCs }
const collapsedLabel = `▸ ${secondary.label}`
const expandedLabel = `▾ ${secondary.label}`
---

{
  (hasCs || hasEn) && (
    <div
      class="mt-10 max-w-[840px] space-y-8 font-sans text-[1.25rem] leading-relaxed text-white/90 md:text-[1.35rem] lg:text-[1.4rem]"
      data-portfolio-descriptions
    >
      {primary.has && primary.data && (
        <section>
          <div class="[&_a]:text-secondary [&_a]:underline [&_p]:mb-3">
            <StructuredText data={primary.data} />
          </div>
        </section>
      )}

      {secondary.has && secondary.data && (
        <section>
          <button
            type="button"
            data-description-toggle
            data-label-collapsed={collapsedLabel}
            data-label-expanded={expandedLabel}
            aria-expanded="false"
            class="cursor-pointer border-none bg-transparent font-anton text-[1.5rem] uppercase tracking-wide text-secondary transition-colors hover:text-white"
          >
            {collapsedLabel}
          </button>
          <div
            data-description-secondary
            class="mt-3 [&_a]:text-secondary [&_a]:underline [&_p]:mb-3"
          >
            <StructuredText data={secondary.data} />
          </div>
        </section>
      )}
    </div>
  )
}

<script>
  import '~/scripts/portfolio-descriptions.ts'
</script>
