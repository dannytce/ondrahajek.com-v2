---
import DatoImageCover from '~/components/DatoImageCover.astro'
import type { ResponsiveImage } from '~/api/generated/types'

interface Props {
  title: string
  video: string
  poster?: ResponsiveImage | null
  transitionName?: string
  deferLoad?: boolean
}

function buildIframeSrc(video: string): string {
  const base = video.trim().replace(/\/$/, '')

  try {
    const url = new URL(base)
    url.searchParams.set('autoplay', '0')
    url.searchParams.set('loop', '1')
    url.searchParams.set('autopause', '0')

    if (
      url.hostname.includes('youtube.com') &&
      url.pathname.includes('/embed/')
    ) {
      const id = url.pathname.split('/').pop()
      if (id) {
        url.searchParams.set('playlist', id)
      }
    }

    return url.toString()
  } catch {
    return `${base}/?autoplay=1&loop=1&autopause=0`
  }
}

const { title, video, poster, transitionName, deferLoad = false } = Astro.props
const iframeSrc = buildIframeSrc(video)
---

<div class="h-full">
  <div
    class="relative w-full overflow-hidden bg-black shadow-[0_10px_30px_rgba(0,0,0,0.75)]"
    data-player-root
    data-loaded={poster ? 'false' : 'true'}
  >
    {
      poster && (
        <div
          class="player-poster absolute inset-0 z-10 transition-opacity duration-[220ms] ease-[cubic-bezier(0.23,1,0.32,1)]"
          style={
            transitionName
              ? `view-transition-name:${transitionName}`
              : undefined
          }
        >
          <DatoImageCover
            data={{
              ...poster,
              alt: '',
            }}
            class="absolute inset-0"
            imgClass="h-full w-full object-cover"
            priority
            layout="fill"
            objectFit="cover"
          />
        </div>
      )
    }
    <div class="relative h-0 w-full pb-[56.25%]">
      <iframe
        src={deferLoad ? undefined : iframeSrc}
        data-player-src={deferLoad ? iframeSrc : undefined}
        title={`${title} video`}
        allow="autoplay; fullscreen"
        class="player-frame absolute left-0 top-0 h-full max-h-[calc(100vh-120px)] w-full border-0 transition-opacity duration-[260ms] ease-[cubic-bezier(0.23,1,0.32,1)]"
      ></iframe>
    </div>
  </div>
</div>

<script>
  import '~/scripts/player.ts'
</script>

<style>
  [data-player-root][data-loaded='false'] .player-poster {
    opacity: 1;
    pointer-events: auto;
  }

  [data-player-root][data-loaded='true'] .player-poster {
    opacity: 0;
    pointer-events: none;
  }

  [data-player-root][data-loaded='false'] .player-frame {
    opacity: 0;
  }

  [data-player-root][data-loaded='true'] .player-frame {
    opacity: 1;
  }
</style>
