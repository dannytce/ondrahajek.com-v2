---
import HeaderHero from '~/components/header/HeaderHero.astro'
import HeaderNav from '~/components/header/HeaderNav.astro'
import TrustedBy from '~/components/About/TrustedBy.astro'
import type { ResponsiveImage } from '~/api/generated/types'
import { t, localePath, getAlternateLocale, type Locale } from '~/i18n'
import { localizedPagePath } from '~/i18n/routes'

interface Props {
  isAboutPage?: boolean
  isHomepage?: boolean
  /** Shorter hero (category pages with compact body layout). */
  compact?: boolean
  title: string
  subTitle?: string
  headerBackground: ResponsiveImage
  currentPath?: string
  locale?: Locale
  pagePath?: string
  /** Full URL path for language switch (other locale). Overrides pagePath when set. */
  switchHref?: string
}

const {
  title,
  subTitle,
  isAboutPage = false,
  isHomepage = false,
  compact = false,
  headerBackground,
  currentPath = '/',
  locale = 'en',
  pagePath = '/',
  switchHref,
} = Astro.props

const navLinks = [
  {
    text: t(locale, 'nav.drone'),
    link: localePath(locale, localizedPagePath(locale, 'drone')),
  },
  {
    text: t(locale, 'nav.video'),
    link: localePath(locale, localizedPagePath(locale, 'video')),
  },
  {
    text: t(locale, 'nav.gallery'),
    link: localePath(locale, localizedPagePath(locale, 'gallery')),
  },
  {
    text: t(locale, 'nav.about'),
    link: localePath(locale, localizedPagePath(locale, 'about')),
  },
]

const altLocale = getAlternateLocale(locale)
const switchUrl = switchHref ?? localePath(altLocale, pagePath)
---

<div
  data-site-header
  data-homepage={isHomepage ? 'true' : 'false'}
  data-compact={compact ? 'true' : 'false'}
  data-video-ready={isHomepage ? 'false' : 'true'}
>
  <HeaderHero
    isHomepage={isHomepage}
    compact={compact}
    title={title}
    subTitle={subTitle}
    headerBackground={headerBackground}
  />

  {isAboutPage ? <TrustedBy /> : null}

  <HeaderNav
    locale={locale}
    currentPath={currentPath}
    switchUrl={switchUrl}
    navLinks={navLinks}
  />
</div>

<script>
  import '~/scripts/header.ts'
</script>

<style>
  [data-site-header][data-video-ready='false'] .header-video {
    opacity: 0;
  }

  [data-site-header][data-video-ready='true'] .header-video {
    opacity: 1;
  }

  [data-site-header][data-homepage='true'][data-video-ready='true']
    .header-fallback {
    opacity: 0;
  }

  .header-video,
  .header-fallback,
  .site-nav,
  .site-nav-gradient {
    transition-property: opacity, transform;
  }

  .site-nav {
    transition-duration: 300ms;
    transition-timing-function: ease-out;
  }

  .site-nav-gradient {
    opacity: 0;
    transition-duration: 300ms;
    background: linear-gradient(
      to bottom,
      rgba(13, 13, 16, 0.95) 0%,
      rgba(13, 13, 16, 0.7) 35%,
      rgba(13, 13, 16, 0.3) 70%,
      transparent 100%
    );
  }

  [data-site-nav][data-visible='false'] {
    transform: translateY(-100%);
    opacity: 0;
  }

  [data-site-nav][data-visible='true'] {
    transform: translateY(0);
    opacity: 1;
  }

  [data-site-nav][data-past-hero='true'] .site-nav-gradient {
    opacity: 1;
  }
</style>
