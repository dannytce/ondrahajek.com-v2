---
import HeaderHero from '~/components/header/HeaderHero.astro'
import TrustedBy from '~/components/About/TrustedBy.astro'
import type { ResponsiveImage } from '~/api/generated/types'

interface Props {
  isAboutPage?: boolean
  isHomepage?: boolean
  /** Shorter hero (category pages with compact body layout). */
  compact?: boolean
  isHeroVisible?: boolean
  /** Full-viewport hero (100svh) with bottom-aligned title. Implied by isAboutPage. */
  fullViewport?: boolean
  title: string
  subTitle?: string
  /** Homepage: SEO-friendly multi-line H1 (overrides title/subTitle in hero). */
  homepageHero?: {
    brand: string
    line: string
    tagline: string
    descriptor: string
  }
  headerBackground: ResponsiveImage
}

const {
  title,
  subTitle,
  homepageHero,
  isAboutPage = false,
  isHomepage = false,
  compact = false,
  isHeroVisible = true,
  fullViewport = false,
  headerBackground,
} = Astro.props

const useFullViewport = isAboutPage || fullViewport
---

<div data-site-header>
  {
    isHeroVisible && (
      <HeaderHero
        isHomepage={isHomepage}
        compact={compact}
        fullViewport={useFullViewport}
        title={title}
        subTitle={subTitle}
        homepageHero={homepageHero}
        headerBackground={headerBackground}
      >
        {isAboutPage && <TrustedBy slot="trustedBy" />}
      </HeaderHero>
    )
  }
</div>
