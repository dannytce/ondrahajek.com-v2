---
import HeaderHero from '~/components/header/HeaderHero.astro'
import HeaderNav from '~/components/header/HeaderNav.astro'
import TrustedBy from '~/components/About/TrustedBy.astro'
import type { ResponsiveImage } from '~/api/generated/types'
import { t, localePath, getAlternateLocale, type Locale } from '~/i18n'
import { getNavLinks } from '~/lib/navigation'

interface Props {
  isAboutPage?: boolean
  isHomepage?: boolean
  /** Shorter hero (category pages with compact body layout). */
  compact?: boolean
  isHeroVisible?: boolean
  title: string
  subTitle?: string
  /** Homepage: SEO-friendly multi-line H1 (overrides title/subTitle in hero). */
  homepageHero?: {
    brand: string
    line: string
    tagline: string
    descriptor: string
  }
  headerBackground: ResponsiveImage
  currentPath?: string
  locale?: Locale
  pagePath?: string
  /** Full URL path for language switch (other locale). Overrides pagePath when set. */
  switchHref?: string
}

const {
  title,
  subTitle,
  homepageHero,
  isAboutPage = false,
  isHomepage = false,
  compact = false,
  isHeroVisible = true,
  headerBackground,
  currentPath = '/',
  locale = 'en',
  pagePath = '/',
  switchHref,
} = Astro.props

const navLinks = getNavLinks(locale)

const altLocale = getAlternateLocale(locale)
const switchUrl = switchHref ?? localePath(altLocale, pagePath)
---

<div data-site-header>
  <HeaderNav
    locale={locale}
    currentPath={currentPath}
    switchUrl={switchUrl}
    navLinks={navLinks}
  />

  {
    isHeroVisible && (
      <HeaderHero
        isHomepage={isHomepage}
        compact={compact}
        title={title}
        subTitle={subTitle}
        homepageHero={homepageHero}
        headerBackground={headerBackground}
      />
    )
  }

  {isAboutPage ? <TrustedBy /> : null}
</div>

<script>
  import '~/scripts/header.ts'
</script>
