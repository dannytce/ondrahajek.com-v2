---
import DatoImageCover from '~/components/DatoImageCover.astro';
import PlayShowreel from '~/components/PlayShowreel.astro';
import TrustedBy from '~/components/About/TrustedBy.astro';
import type { ResponsiveImage } from '~/api/generated/types';
import {
  t,
  localePath,
  getAlternateLocale,
  type Locale,
} from '~/i18n';

interface Props {
  isAboutPage?: boolean;
  isHomepage?: boolean;
  title: string;
  subTitle?: string;
  headerBackground: ResponsiveImage;
  currentPath?: string;
  locale?: Locale;
  pagePath?: string;
}

const {
  title,
  subTitle,
  isAboutPage = false,
  isHomepage = false,
  headerBackground,
  currentPath = '/',
  locale = 'en',
  pagePath = '/',
} = Astro.props;

const navLinks = [
  { text: t(locale, 'nav.drone'), link: localePath(locale, '/drone-cinematography') },
  { text: t(locale, 'nav.video'), link: localePath(locale, '/video-production') },
  { text: t(locale, 'nav.gallery'), link: localePath(locale, '/gallery') },
  { text: t(locale, 'nav.about'), link: localePath(locale, '/about') },
];

const altLocale = getAlternateLocale(locale);
const switchUrl = localePath(altLocale, pagePath);
---

<div
  data-site-header
  data-homepage={isHomepage ? 'true' : 'false'}
  data-video-ready={isHomepage ? 'false' : 'true'}
>
  <header class="top-0 w-full h-header flex flex-col justify-center fixed z-header">
    <div class="w-full max-w-container mx-auto px-[15px] xl:px-0 relative z-headerContainer flex flex-col flex-1 justify-center md:flex-none md:justify-start md:flex-row">
      {
        subTitle ? (
          <div class="flex flex-col justify-center">
            <h1 class="text-[6rem] md:text-[10rem] font-teko font-semibold uppercase m-0 p-0">
              {title}
            </h1>
            <h2 class="text-[1.8rem] md:text-[3rem] font-teko uppercase -mt-[0.75em] m-0 p-0">
              {subTitle}
            </h2>
          </div>
        ) : (
          <h1 class="text-[6rem] md:text-[10rem] font-teko font-semibold uppercase m-0 p-0">
            {title}
          </h1>
        )
      }
      {isHomepage ? <PlayShowreel /> : null}
    </div>

    {
      isHomepage && (
        <div class="header-video-wrap fixed top-0 w-full h-full overflow-hidden z-video">
          <video
            data-header-video
            autoplay
            playsinline
            loop
            muted
            class="header-video box-border h-[56.25vw] left-1/2 min-h-full min-w-full -translate-x-1/2 -translate-y-1/2 absolute top-1/2 w-[177.78vh] pointer-events-none object-cover"
          >
            <source src="/bg-mobile.mp4" type="video/mp4" media="(max-width: 375px)" />
            <source src="/bg-tablet.mp4" type="video/mp4" media="(max-width: 767px)" />
            <source src="/bg-desktop.mp4" type="video/mp4" />
          </video>
        </div>
      )
    }

    <div class="header-fallback absolute top-0 left-0 right-0 bottom-0 z-header transition-opacity duration-[400ms] ease-[ease]">
      <div class="min-h-header">
        <DatoImageCover
          data={{ ...headerBackground, alt: '' }}
          class="absolute inset-0 z-[2] min-h-header pointer-events-none"
          imgClass="h-full w-full object-cover"
          priority
          layout="fill"
          objectFit="cover"
        />
      </div>
    </div>
  </header>

  {isAboutPage ? <TrustedBy /> : null}

  <div data-site-nav data-visible="true" data-past-hero="false" class="site-nav fixed left-0 right-0 top-0 z-nav pointer-events-none">
    <div class="site-nav-gradient absolute inset-x-0 h-48 pointer-events-none -z-10" />
    <nav class="w-full top-[30px] md:top-[63px] relative">
      <div class="w-full max-w-container mx-auto px-[15px] xl:px-0 flex justify-between">
        <a href={localePath(locale, '/')} class="pointer-events-auto">
          <img src="/logo-ondrahajek.svg" alt="ONDRAHAJEK.COM" />
        </a>
        <div class="flex flex-col items-end gap-1">
          <ul class="p-0 m-0 list-none">
            {navLinks.map((item) => (
              <li class="first:[&_a]:pt-0">
                <a
                  href={item.link}
                  class:list={[
                    'block text-[2rem] font-teko text-white no-underline uppercase text-right pointer-events-auto py-[clamp(5px,1.2vh,10px)] link-animation',
                    currentPath === item.link && 'active',
                  ]}
                >
                  {item.text}
                </a>
              </li>
            ))}
          </ul>
          <a
            href={switchUrl}
            class="pointer-events-auto text-secondary text-[1.4rem] font-teko uppercase no-underline hover:text-white transition-colors"
          >
            {t(locale, 'lang.switch')}
          </a>
        </div>
      </div>
    </nav>
  </div>
</div>

<script>
  import '~/scripts/header.ts';
</script>

<style>
  [data-site-header][data-video-ready='false'] .header-video {
    opacity: 0;
  }

  [data-site-header][data-video-ready='true'] .header-video {
    opacity: 1;
  }

  [data-site-header][data-homepage='true'][data-video-ready='true'] .header-fallback {
    opacity: 0;
  }

  .header-video,
  .header-fallback,
  .site-nav,
  .site-nav-gradient {
    transition-property: opacity, transform;
  }

  .site-nav {
    transition-duration: 300ms;
    transition-timing-function: ease-out;
  }

  .site-nav-gradient {
    opacity: 0;
    transition-duration: 300ms;
    background: linear-gradient(
      to bottom,
      rgba(13, 13, 16, 0.95) 0%,
      rgba(13, 13, 16, 0.7) 35%,
      rgba(13, 13, 16, 0.3) 70%,
      transparent 100%
    );
  }

  [data-site-nav][data-visible='false'] {
    transform: translateY(-100%);
    opacity: 0;
  }

  [data-site-nav][data-visible='true'] {
    transform: translateY(0);
    opacity: 1;
  }

  [data-site-nav][data-past-hero='true'] .site-nav-gradient {
    opacity: 1;
  }
</style>
