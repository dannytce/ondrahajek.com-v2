---
import HeaderHero from '~/components/header/HeaderHero.astro'
import TrustedBy from '~/components/About/TrustedBy.astro'
import type { ResponsiveImage } from '~/api/generated/types'

interface Props {
  isAboutPage?: boolean
  isHomepage?: boolean
  /** Shorter hero (category pages with compact body layout). */
  compact?: boolean
  isHeroVisible?: boolean
  title: string
  subTitle?: string
  /** Homepage: SEO-friendly multi-line H1 (overrides title/subTitle in hero). */
  homepageHero?: {
    brand: string
    line: string
    tagline: string
    descriptor: string
  }
  headerBackground: ResponsiveImage
}

const {
  title,
  subTitle,
  homepageHero,
  isAboutPage = false,
  isHomepage = false,
  compact = false,
  isHeroVisible = true,
  headerBackground,
} = Astro.props
---

<div data-site-header>
  {
    isHeroVisible &&
      (isAboutPage ? (
        <HeaderHero
          isHomepage={isHomepage}
          compact={compact}
          fullViewport
          title={title}
          subTitle={subTitle}
          homepageHero={homepageHero}
          headerBackground={headerBackground}
        >
          <slot name="aboutOverlay" slot="aboutOverlay" />
          <TrustedBy slot="trustedBy" />
        </HeaderHero>
      ) : (
        <HeaderHero
          isHomepage={isHomepage}
          compact={compact}
          fullViewport={false}
          title={title}
          subTitle={subTitle}
          homepageHero={homepageHero}
          headerBackground={headerBackground}
        />
      ))
  }
</div>
