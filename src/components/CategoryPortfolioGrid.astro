---
import PortfolioCard from '~/components/PortfolioCard.astro'
import PortfolioFilterToolbar from '~/components/PortfolioFilterToolbar.astro'
import PortfolioFiltersPanel from '~/components/PortfolioFiltersPanel.astro'
import { t, projectCountLabel, type Locale } from '~/i18n'
import type { PortfolioListItem } from '~/api'
import { buildFilterOptions } from '~/lib/portfolio-filters'
import { splitPortfolioTags } from '~/lib/portfolio-tags'

interface Props {
  portfolios: PortfolioListItem[]
  locale: Locale
  /** Used for SEO meta + deep links from detail (e.g. video-production, drone-cinematography). */
  categorySlug: 'video-production' | 'drone-cinematography'
  /** Restored when no filters are active (client-side meta sync). */
  defaultSeoTitle: string
  defaultSeoDescription: string
}

const {
  portfolios,
  locale,
  categorySlug,
  defaultSeoTitle,
  defaultSeoDescription,
} = Astro.props

/** PortfolioCard renders nothing without a thumbnail — exclude from grid and filter model. */
const gridPortfolios = portfolios.filter((p) => p.thumbnail?.responsiveImage)

const {
  subcategories,
  years,
  locations,
  clients,
  locationSlugByValue,
  clientSlugByValue,
} = buildFilterOptions(gridPortfolios)

const categoryTitleKey =
  categorySlug === 'drone-cinematography'
    ? 'category.drone.title'
    : 'category.video.title'
const categoryIntroKey =
  categorySlug === 'drone-cinematography'
    ? 'category.drone.intro'
    : 'category.video.intro'
---

<section
  class="mx-auto w-full max-w-container px-5 pb-12 pt-28 xl:px-0"
  data-portfolio-grid
  data-category-slug={categorySlug}
  data-locale={locale}
  data-default-seo-title={defaultSeoTitle}
  data-default-seo-description={defaultSeoDescription}
>
  <div class="portfolio-toolbar-enter flex flex-col gap-4">
    <PortfolioFilterToolbar
      locale={locale}
      totalCount={gridPortfolios.length}
      categoryTitle={t(locale, categoryTitleKey)}
    />
    <p class="m-0 max-w-[72ch] font-inter text-[1.15rem] leading-relaxed text-foreground-muted">
      {t(locale, categoryIntroKey)}
    </p>
  </div>
  <div class="portfolio-toolbar-enter relative z-40 mb-8 mt-4 flex justify-end">
    <div class="flex items-center gap-3">
      <span class="font-geist text-[1.2rem] text-[#888888]">
        <span
          data-filter-result-count
          data-locale={locale}
          data-label-one={t(locale, 'filter.project.one')}
          data-label-few={t(locale, 'filter.project.few')}
          data-label-other={t(locale, 'filter.project.other')}
        >
          {gridPortfolios.length}
        </span>{' '}
        <span data-filter-result-label>{projectCountLabel(locale, gridPortfolios.length)}</span>
      </span>

      <button
        type="button"
        data-filter-toggle
        aria-expanded="false"
        aria-controls="portfolio-filters-panel"
        aria-label={t(locale, 'filter.toggleFilters')}
        class="inline-flex h-12 items-center gap-2 rounded-full border border-[#222222] bg-transparent px-5 font-geist text-[1.2rem] uppercase tracking-[0.08em] text-[#c2c2c4] transition-colors hover:border-white/35 hover:text-white focus:outline-none focus-visible:border-white/60"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M4 6h16M7 12h10M10 18h4"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
          ></path>
        </svg>
        <span>{t(locale, 'filter.refine')}</span>
        <span
          data-filter-active-badge
          hidden
          class="inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-white px-1.5 text-[1rem] font-semibold leading-none text-black"
        ></span>
      </button>
    </div>

    <PortfolioFiltersPanel
      locale={locale}
      subcategories={subcategories}
      years={years}
      locations={locations}
      clients={clients}
    />
  </div>

  <p
    data-filter-empty
    hidden
    class="py-20 text-center font-inter text-[1.8rem] text-secondary"
  >
    {t(locale, 'filter.noResults')}
  </p>

  <ul
    class="m-0 grid w-full list-none grid-cols-1 gap-4 p-0 sm:grid-cols-2 lg:grid-cols-3"
  >
    {
      gridPortfolios.map((portfolio, index) => {
        const year = portfolio.date
          ? new Date(portfolio.date).getFullYear().toString()
          : ''
        const location = portfolio.location?.trim() ?? ''
        const client = portfolio.client?.trim() ?? ''
        const locationSlug = location
          ? (locationSlugByValue.get(location) ?? '')
          : ''
        const clientSlug = client ? (clientSlugByValue.get(client) ?? '') : ''
        const search = [
          portfolio.title,
          portfolio.subtitle,
          portfolio.subtitleCs,
          portfolio.subtitleEn,
          portfolio.tagsSearchText,
          portfolio.client,
          portfolio.location,
        ]
          .filter(Boolean)
          .join(' ')
          .toLowerCase()

        return (
          <li
            class="portfolio-grid-item-enter"
            style={{ '--stagger': String(Math.min(index, 20)) }}
            data-portfolio-item
            data-subcategories={portfolio.subcategory
              .map((subcategory) => subcategory.slug?.trim())
              .filter(Boolean)
              .join(',')}
            data-tag-keys={splitPortfolioTags(portfolio.tags).join(',')}
            data-year={year !== 'NaN' ? year : ''}
            data-location={location}
            data-client={client}
            data-location-slug={locationSlug}
            data-client-slug={clientSlug}
            data-search={search}
          >
            <PortfolioCard portfolio={portfolio} locale={locale} />
          </li>
        )
      })
    }
  </ul>
</section>

<script>
  import '~/scripts/portfolio-filters.ts'
  import '~/scripts/category-seo-meta.ts'
</script>
