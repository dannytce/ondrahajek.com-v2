---
import PortfolioCard from '~/components/PortfolioCard.astro'
import { t, type Locale } from '~/i18n'
import type { PortfolioListItem } from '~/api'
import { buildSlugMapsFromPortfolios } from '~/lib/portfolio-filter-slugs'
import { splitPortfolioTags } from '~/lib/portfolio-tags'

interface FilterOption {
  value: string
  label: string
}

interface Props {
  portfolios: PortfolioListItem[]
  locale: Locale
  /** Used for SEO meta + deep links from detail (e.g. video-production, drone-cinematography). */
  categorySlug: 'video-production' | 'drone-cinematography'
  /** Restored when no filters are active (client-side meta sync). */
  defaultSeoTitle: string
  defaultSeoDescription: string
}

const {
  portfolios,
  locale,
  categorySlug,
  defaultSeoTitle,
  defaultSeoDescription,
} = Astro.props

const subcategoryMap = new Map<string, string>()
for (const portfolio of portfolios) {
  for (const subcategory of portfolio.subcategory) {
    const slug = subcategory.slug?.trim()
    const label = subcategory.name?.trim()
    if (slug && label) {
      subcategoryMap.set(slug, label)
    }
  }
}

const subcategories: FilterOption[] = Array.from(
  subcategoryMap,
  ([value, label]) => ({
    value,
    label,
  })
).sort((a, b) => a.label.localeCompare(b.label))

const yearSet = new Set<string>()
for (const portfolio of portfolios) {
  if (!portfolio.date) continue

  const year = new Date(portfolio.date).getFullYear().toString()
  if (year !== 'NaN') {
    yearSet.add(year)
  }
}

const years: FilterOption[] = Array.from(yearSet)
  .sort((a, b) => Number(b) - Number(a))
  .map((value) => ({ value, label: value }))

const { locationSlugByValue, clientSlugByValue } =
  buildSlugMapsFromPortfolios(portfolios)

const locations: FilterOption[] = [...locationSlugByValue.entries()]
  .sort((a, b) => a[0].localeCompare(b[0]))
  .map(([label, value]) => ({ value, label }))

const clients: FilterOption[] = [...clientSlugByValue.entries()]
  .sort((a, b) => a[0].localeCompare(b[0]))
  .map(([label, value]) => ({ value, label }))
---

<div
  class="mx-auto w-full max-w-container px-[15px] xl:px-0"
  data-portfolio-grid
  data-category-slug={categorySlug}
  data-locale={locale}
  data-default-seo-title={defaultSeoTitle}
  data-default-seo-description={defaultSeoDescription}
>
  <div class="portfolio-toolbar-enter mb-10 flex flex-col gap-4">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div
        class="flex w-full shrink-0 items-center justify-end gap-2 sm:w-auto"
      >
        <button
          type="button"
          data-filter-toggle
          class="filter-toggle-btn"
          aria-expanded="false"
          aria-controls="portfolio-filters-panel"
          aria-label={t(locale, 'filter.toggleFilters')}
        >
          <svg
            class="h-6 w-6"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"
            ></polygon>
          </svg>
          <span
            data-filter-active-badge
            hidden
            class="pointer-events-none absolute -right-4 -top-4 flex min-h-[1.8rem] min-w-[1.8rem] items-center justify-center rounded-full bg-secondary px-0.5 font-teko text-[1.1rem] font-semibold tabular-nums leading-none text-background ring-2 ring-background"
            aria-hidden="true"
          >
            0
          </span>
        </button>
        <span class="font-roboto text-[1.3rem] text-secondary/60">
          <span data-filter-result-count>{portfolios.length}</span> / {
            portfolios.length
          }{' '}
          {t(locale, 'filter.results')}
        </span>
      </div>

      <div class="flex min-w-0 flex-1 flex-wrap gap-2">
        {
          subcategories.length > 0 && (
            <div class="flex flex-wrap gap-2">
              <button
                type="button"
                data-filter-subcategory=""
                data-active="true"
                class="filter-subcategory-chip cursor-pointer border border-white bg-white px-4 py-1 font-teko text-[1.6rem] uppercase text-background transition-colors data-[active=false]:border-secondary/40 data-[active=false]:bg-transparent data-[active=false]:text-secondary data-[active=false]:hover:border-white data-[active=false]:hover:text-white"
              >
                {t(locale, 'filter.all')}
              </button>
              {subcategories.map((subcategory) => (
                <button
                  type="button"
                  data-filter-subcategory={subcategory.value}
                  data-active="false"
                  class="filter-subcategory-chip cursor-pointer border border-white bg-white px-4 py-1 font-teko text-[1.6rem] uppercase text-background transition-colors data-[active=false]:border-secondary/40 data-[active=false]:bg-transparent data-[active=false]:text-secondary data-[active=false]:hover:border-white data-[active=false]:hover:text-white"
                >
                  {subcategory.label}
                </button>
              ))}
            </div>
          )
        }
      </div>
    </div>

    <div
      id="portfolio-filters-panel"
      data-filter-panel
      class="flex hidden flex-wrap items-center justify-end gap-3"
    >
      {
        years.length > 0 && (
          <select
            data-filter-year
            class="filter-select w-full max-w-full shrink-0 md:w-[9rem] md:min-w-[9rem] md:max-w-[9rem]"
          >
            <option value="">{t(locale, 'filter.year')}</option>
            {years.map((year) => (
              <option value={year.value}>{year.label}</option>
            ))}
          </select>
        )
      }

      {
        locations.length > 0 && (
          <select
            data-filter-location
            class="filter-select w-full max-w-full shrink-0 md:w-[14rem] md:min-w-[14rem] md:max-w-[14rem]"
          >
            <option value="">{t(locale, 'filter.location')}</option>
            {locations.map((location) => (
              <option value={location.value}>{location.label}</option>
            ))}
          </select>
        )
      }

      {
        clients.length > 0 && (
          <select
            data-filter-client
            class="filter-select w-full max-w-full shrink-0 md:w-[16rem] md:min-w-[16rem] md:max-w-[16rem]"
          >
            <option value="">{t(locale, 'filter.client')}</option>
            {clients.map((client) => (
              <option value={client.value}>{client.label}</option>
            ))}
          </select>
        )
      }

      <input
        type="text"
        data-filter-search
        placeholder={t(locale, 'filter.search')}
        class="filter-search-input w-full min-w-[200px] max-w-[22rem] sm:w-auto"
      />

      <button
        type="button"
        data-filter-clear
        hidden
        class="cursor-pointer border-none bg-transparent font-teko text-[1.4rem] uppercase text-secondary transition-colors hover:text-white"
      >
        {t(locale, 'filter.clear')}
      </button>
    </div>
  </div>

  <p
    data-filter-empty
    hidden
    class="py-20 text-center font-roboto text-[1.8rem] text-secondary"
  >
    {t(locale, 'filter.noResults')}
  </p>

  <ul
    class="m-0 grid w-full list-none grid-cols-1 gap-12 p-0 sm:grid-cols-2 lg:grid-cols-3"
  >
    {
      portfolios.map((portfolio, index) => {
        const year = portfolio.date
          ? new Date(portfolio.date).getFullYear().toString()
          : ''
        const location = portfolio.location?.trim() ?? ''
        const client = portfolio.client?.trim() ?? ''
        const locationSlug = location
          ? (locationSlugByValue.get(location) ?? '')
          : ''
        const clientSlug = client ? (clientSlugByValue.get(client) ?? '') : ''
        const search = [
          portfolio.title,
          portfolio.subtitle,
          portfolio.subtitleCs,
          portfolio.subtitleEn,
          portfolio.tagsSearchText,
          portfolio.client,
          portfolio.location,
        ]
          .filter(Boolean)
          .join(' ')
          .toLowerCase()

        return (
          <li
            class="portfolio-grid-item-enter"
            style={{ '--stagger': String(Math.min(index, 20)) }}
            data-portfolio-item
            data-subcategories={portfolio.subcategory
              .map((subcategory) => subcategory.slug?.trim())
              .filter(Boolean)
              .join(',')}
            data-tag-keys={splitPortfolioTags(portfolio.tags).join(',')}
            data-year={year !== 'NaN' ? year : ''}
            data-location={location}
            data-client={client}
            data-location-slug={locationSlug}
            data-client-slug={clientSlug}
            data-search={search}
          >
            <PortfolioCard portfolio={portfolio} locale={locale} />
          </li>
        )
      })
    }
  </ul>
</div>

<script>
  import '~/scripts/portfolio-filters.ts'
  import '~/scripts/category-seo-meta.ts'
</script>
