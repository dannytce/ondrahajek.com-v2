---
import Heading from '~/components/Heading.astro'
import PortfolioCard from '~/components/PortfolioCard.astro'
import { t, type Locale } from '~/i18n'
import type { PortfolioListItem } from '~/api'

interface Props {
  portfolios: PortfolioListItem[]
  locale: Locale
}

const { portfolios, locale } = Astro.props

/** PortfolioCard renders nothing without a responsive thumbnail — skip those so the grid has no empty cells. */
const withThumbnails = portfolios.filter((p) => p.thumbnail?.responsiveImage)
const featuredTitle = t(locale, 'home.featured')
const projectsLabel = t(locale, 'home.projectsLabel')
---

{
  withThumbnails.length > 0 && (
    <section
      class="mx-auto w-full max-w-container bg-black px-5 py-12 md:bg-transparent xl:px-0"
      data-featured-work
      data-locale={locale}
    >
      <div class="portfolio-toolbar-enter mb-8 flex items-end justify-between gap-4">
        <Heading level={2} size="subtitle" class="m-0 text-white">
          {featuredTitle}
        </Heading>
        <div class="hidden font-geist text-[1rem] uppercase tracking-[0.2em] text-[#8F8F8F] md:block">
          {withThumbnails.length} {projectsLabel}
        </div>
      </div>
      <ul class="m-0 grid w-full list-none grid-cols-1 gap-x-4 gap-y-7 p-0 md:grid-cols-2 lg:grid-cols-3 lg:gap-x-5 lg:gap-y-8">
        {withThumbnails.map((portfolio, index) => (
          <li
            class="portfolio-grid-item-enter"
            style={{ '--stagger': String(Math.min(index, 20)) }}
          >
            <PortfolioCard portfolio={portfolio} locale={locale} />
          </li>
        ))}
      </ul>
    </section>
  )
}
