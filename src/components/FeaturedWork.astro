---
import PortfolioCard from '~/components/PortfolioCard.astro'
import { t, type Locale } from '~/i18n'
import type { PortfolioListItem } from '~/api'

interface Props {
  portfolios: PortfolioListItem[]
  locale: Locale
}

const { portfolios, locale } = Astro.props

/** PortfolioCard renders nothing without a responsive thumbnail — skip those so the grid has no empty cells. */
const withThumbnails = portfolios.filter((p) => p.thumbnail?.responsiveImage)
const initialVisibleCount = 6
---

{
  withThumbnails.length > 0 && (
    <section class="mx-auto w-full max-w-container px-5 py-12 xl:px-0" data-featured-work>
      <div class="portfolio-toolbar-enter mb-8 flex items-end justify-between gap-4">
        <h2 class="m-0 font-anton text-[3.2rem] text-white md:text-[5rem]">
          {t(locale, 'home.featured')}
        </h2>
        <div class="hidden font-geist text-[1rem] uppercase tracking-[0.2em] text-[#8F8F8F] md:block">
          {withThumbnails.length} {locale === 'cs' ? 'projektů' : 'projects'}
        </div>
      </div>
      <ul class="m-0 grid w-full list-none grid-cols-1 gap-4 p-0 md:grid-cols-2 md:gap-4 lg:grid-cols-3">
        {withThumbnails.map((portfolio, index) => (
          <li
            class="portfolio-grid-item-enter"
            style={{ '--stagger': String(Math.min(index, 20)) }}
            data-featured-item
            hidden={index >= initialVisibleCount}
          >
            <PortfolioCard portfolio={portfolio} locale={locale} />
          </li>
        ))}
      </ul>

      <div class="portfolio-toolbar-enter-delayed mt-8 flex justify-center md:mt-10">
        <button
          type="button"
          data-view-all-projects
          class="inline-flex items-center gap-2 rounded-full border border-[#222222] px-6 py-3 font-inter text-[1.3rem] font-medium text-white no-underline transition-colors hover:border-white/30"
        >
          <span data-view-all-label>
            {locale === 'cs' ? 'Zobrazit všechny projekty' : 'View All Projects'}
          </span>
          <span aria-hidden="true">→</span>
        </button>
      </div>
    </section>
  )
}

<script>
  const root = document.querySelector<HTMLElement>('[data-featured-work]')
  if (root) {
    const toggleBtn = root.querySelector<HTMLButtonElement>('[data-view-all-projects]')
    const label = root.querySelector<HTMLElement>('[data-view-all-label]')
    const items = Array.from(root.querySelectorAll<HTMLElement>('[data-featured-item]'))
    const initialVisibleCount = 6
    const isCs = document.documentElement.lang === 'cs'
    let expanded = false

    const apply = () => {
      items.forEach((item, index) => {
        item.hidden = !expanded && index >= initialVisibleCount
      })
      if (label) {
        label.textContent = expanded
          ? isCs
            ? 'Zobrazit méně'
            : 'Show Less'
          : isCs
            ? 'Zobrazit všechny projekty'
            : 'View All Projects'
      }
    }

    toggleBtn?.addEventListener('click', () => {
      expanded = !expanded
      apply()
    })

    apply()
  }
</script>
