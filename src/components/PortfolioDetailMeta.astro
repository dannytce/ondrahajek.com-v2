---
import { t, type Locale } from '~/i18n'

interface Props {
  locale: Locale
  year: number | null
  client?: string | null
  location?: string | null
  categoryLabel?: string | null
  /** `labeled` = dt/dd (aside). `inline` = values only, middot-separated (mobile under title). */
  variant?: 'labeled' | 'inline'
  /** Extra classes for the root element */
  class?: string
  /** Deep link to category portfolio filtered by client */
  moreForClientHref?: string
  moreForClientLabel?: string
  /** Deep link to category portfolio filtered by location */
  moreInLocationHref?: string
  moreInLocationLabel?: string
}

const {
  locale,
  year,
  client,
  location,
  categoryLabel,
  variant = 'labeled',
  class: className,
  moreForClientHref,
  moreForClientLabel,
  moreInLocationHref,
  moreInLocationLabel,
} = Astro.props

const linkClass =
  'mt-2 inline-block font-anton text-[1.4rem] uppercase tracking-wide text-secondary no-underline transition-colors hover:text-white'

const parts: string[] = []
if (year != null) parts.push(String(year))
if (client?.trim()) parts.push(client.trim())
if (location?.trim()) parts.push(location.trim())

const hasAny = parts.length > 0
const inlineText = parts.join(' · ')
const hasFilterLinks =
  Boolean(moreForClientHref && moreForClientLabel) ||
  Boolean(moreInLocationHref && moreInLocationLabel)
const rows = [
  {
    key: 'client',
    label: t(locale, 'detail.client').toUpperCase(),
    value: client?.trim() ?? '',
  },
  {
    key: 'location',
    label: t(locale, 'detail.location').toUpperCase(),
    value: location?.trim() ?? '',
  },
  {
    key: 'year',
    label: t(locale, 'detail.year').toUpperCase(),
    value: year != null ? String(year) : '',
  },
  {
    key: 'category',
    label: 'CATEGORY',
    value: categoryLabel?.trim() ?? '',
  },
].filter((row) => row.value)
---

{
  hasAny &&
    (variant === 'inline' ? (
      <div class:list={[className]}>
        <p
          class:list={[
            'm-0 font-anton text-[1.5rem] leading-snug tracking-wide text-secondary',
          ]}
        >
          {inlineText}
        </p>
        {
          hasFilterLinks && (
            <p class="m-0 mt-3 flex flex-wrap gap-x-6 gap-y-2">
              {
                moreInLocationHref && moreInLocationLabel && (
                  <a href={moreInLocationHref} class={linkClass}>
                    {moreInLocationLabel}
                  </a>
                )
              }
              {
                moreForClientHref && moreForClientLabel && (
                  <a href={moreForClientHref} class={linkClass}>
                    {moreForClientLabel}
                  </a>
                )
              }
            </p>
          )
        }
      </div>
    ) : (
      <div class:list={['rounded-xl border border-white/10 bg-[#141414] p-6', className]}>
        <dl class="m-0">
          {rows.map((row, index) => (
            <>
              <div class="space-y-1">
                <dt class="font-geist text-[0.9rem] uppercase tracking-[0.2em] text-[#555555]">
                  {row.label}
                </dt>
                <dd class="m-0 font-inter text-[1.4rem] text-white">{row.value}</dd>
              </div>
              {index < rows.length - 1 && <div class="my-4 h-px w-full bg-[#222222]"></div>}
            </>
          ))}
        </dl>
      </div>
    ))
}
