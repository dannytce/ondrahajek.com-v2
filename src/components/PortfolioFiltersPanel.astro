---
import type { FilterOption } from '~/lib/portfolio-filters'
import { t, type Locale } from '~/i18n'

interface Props {
  locale: Locale
  subcategories: FilterOption[]
  years: FilterOption[]
  locations: FilterOption[]
  clients: FilterOption[]
}

const { locale, subcategories, years, locations, clients } = Astro.props
---

<div
  id="portfolio-filters-panel"
  data-filter-panel
  class="flex w-full flex-wrap items-center gap-2"
>
  {
    subcategories.length > 0 && (
      <select
        data-filter-category
        class="w-full max-w-full shrink-0 cursor-pointer rounded-full border border-[#222222] bg-transparent px-4 py-2 font-inter text-[1.2rem] text-[#888888] transition-colors hover:border-white/30 focus:outline-none md:w-[14rem] md:min-w-[14rem] md:max-w-[14rem]"
      >
        <option value="">{locale === 'cs' ? 'Kategorie' : 'Category'}</option>
        {subcategories.map((subcategory) => (
          <option value={subcategory.value}>{subcategory.label}</option>
        ))}
      </select>
    )
  }

  {
    years.length > 0 && (
      <select
        data-filter-year
        class="w-full max-w-full shrink-0 cursor-pointer rounded-full border border-[#222222] bg-transparent px-4 py-2 font-inter text-[1.2rem] text-[#888888] transition-colors hover:border-white/30 focus:outline-none md:w-[9rem] md:min-w-[9rem] md:max-w-[9rem]"
      >
        <option value="">{t(locale, 'filter.year')}</option>
        {years.map((year) => (
          <option value={year.value}>{year.label}</option>
        ))}
      </select>
    )
  }

  {
    locations.length > 0 && (
      <select
        data-filter-location
        class="w-full max-w-full shrink-0 cursor-pointer rounded-full border border-[#222222] bg-transparent px-4 py-2 font-inter text-[1.2rem] text-[#888888] transition-colors hover:border-white/30 focus:outline-none md:w-[14rem] md:min-w-[14rem] md:max-w-[14rem]"
      >
        <option value="">{t(locale, 'filter.location')}</option>
        {locations.map((location) => (
          <option value={location.value}>{location.label}</option>
        ))}
      </select>
    )
  }

  {
    clients.length > 0 && (
      <select
        data-filter-client
        class="w-full max-w-full shrink-0 cursor-pointer rounded-full border border-[#222222] bg-transparent px-4 py-2 font-inter text-[1.2rem] text-[#888888] transition-colors hover:border-white/30 focus:outline-none md:w-[16rem] md:min-w-[16rem] md:max-w-[16rem]"
      >
        <option value="">{t(locale, 'filter.client')}</option>
        {clients.map((client) => (
          <option value={client.value}>{client.label}</option>
        ))}
      </select>
    )
  }

  <div class="hidden flex-1 md:block"></div>

  <button
    type="button"
    data-filter-clear
    hidden
    class="cursor-pointer rounded-full border border-[#222222] bg-transparent px-4 py-2 font-inter text-[1.2rem] text-[#555555] transition-colors hover:border-white/30 hover:text-white md:ml-auto"
  >
    <span class="inline-flex items-center gap-1.5">
      <span aria-hidden="true">×</span>
      <span>{t(locale, 'filter.clear')}</span>
    </span>
  </button>
</div>
