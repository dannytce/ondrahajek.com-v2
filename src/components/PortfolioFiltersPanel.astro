---
import type { FilterOption } from '~/lib/portfolio-filters'
import { projectCountLabel, t, type Locale } from '~/i18n'

interface Props {
  locale: Locale
  totalCount: number
  subcategories: FilterOption[]
  years: FilterOption[]
  locations: FilterOption[]
  clients: FilterOption[]
}

const { locale, totalCount, subcategories, years, locations, clients } = Astro.props
---

<div
  id="portfolio-filters-panel"
  class="w-full"
>
  <div
    class="flex w-full flex-col gap-2.5 md:flex-row md:items-start md:justify-between"
  >
    <div class="flex min-w-0 flex-1 flex-wrap items-center gap-1.5 md:gap-2.5">
      {
        subcategories.length > 0 && (
          <>
            <button
              type="button"
              data-filter-subcategory=""
              data-active="true"
              class="inline-flex cursor-pointer items-center rounded-full border border-[#222222] bg-transparent px-2.5 py-1.5 font-inter text-[1rem] text-[#888888] transition-colors hover:border-white/30 disabled:cursor-not-allowed disabled:opacity-40 disabled:hover:border-[#222222] disabled:hover:bg-transparent disabled:hover:text-[#888888] disabled:data-[active=true]:border-[#222222] disabled:data-[active=true]:bg-transparent disabled:data-[active=true]:text-[#888888] md:px-5 md:py-2.5 md:text-[1.35rem] data-[active=true]:border-white data-[active=true]:bg-white data-[active=true]:text-black"
            >
              {locale === 'cs' ? 'Vše' : 'All'}
            </button>
            {subcategories.map((subcategory) => (
              <button
                type="button"
                data-filter-subcategory={subcategory.value}
                data-active="false"
                class="inline-flex cursor-pointer items-center rounded-full border border-[#222222] bg-transparent px-2.5 py-1.5 font-inter text-[1rem] text-[#888888] transition-colors hover:border-white/30 disabled:cursor-not-allowed disabled:opacity-40 disabled:hover:border-[#222222] disabled:hover:bg-transparent disabled:hover:text-[#888888] disabled:data-[active=true]:border-[#222222] disabled:data-[active=true]:bg-transparent disabled:data-[active=true]:text-[#888888] md:px-5 md:py-2.5 md:text-[1.35rem] data-[active=true]:border-white data-[active=true]:bg-white data-[active=true]:text-black"
              >
                {subcategory.label}
              </button>
            ))}
          </>
        )
      }
    </div>

    <div
      class="flex shrink-0 items-center gap-2.5 self-end md:gap-3 md:self-auto"
    >
      <span class="shrink-0 pt-1 text-right font-geist text-[1.2rem] text-[#888888] md:text-[1.35rem]">
        <span
          data-filter-result-count
          data-locale={locale}
          data-label-one={t(locale, 'filter.project.one')}
          data-label-few={t(locale, 'filter.project.few')}
          data-label-other={t(locale, 'filter.project.other')}
        >
          {totalCount}
        </span>{' '}
        <span data-filter-result-label>{projectCountLabel(locale, totalCount)}</span>
      </span>

      <button
        type="button"
        data-filter-toggle
        data-filter-toggle-active="false"
        aria-expanded="false"
        class="relative inline-flex h-[2.5rem] w-[2.5rem] shrink-0 cursor-pointer items-center justify-center rounded-full border border-white bg-black text-white transition-colors hover:border-white/70 md:h-[3.2rem] md:w-[3.2rem] data-[filter-toggle-active=true]:border-white data-[filter-toggle-active=true]:bg-white data-[filter-toggle-active=true]:text-black"
      >
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          class="h-4 w-4 md:h-5 md:w-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M3 5h18l-7 8v5l-4 2v-7L3 5Z"></path>
        </svg>
        <span
          data-filter-active-badge
          hidden
          class="absolute -right-1 -top-1 inline-flex h-4 min-w-4 items-center justify-center rounded-full bg-black px-1 text-[0.65rem] font-semibold leading-none text-white data-[filter-toggle-active=true]:bg-black data-[filter-toggle-active=true]:text-white md:h-5 md:min-w-5 md:text-[0.75rem]"
        ></span>
      </button>
    </div>
  </div>

  <div
    data-filter-panel
    class="mt-3 hidden w-full md:mt-2"
  >
    <div class="grid grid-cols-1 gap-1.5 md:grid-cols-[minmax(0,17.5rem)_minmax(0,15.5rem)_minmax(0,10.5rem)_auto] md:items-center md:gap-2.5">
      {
        clients.length > 0 && (
          <select
            data-filter-client
            data-filter-active="false"
            class="w-full min-w-0 cursor-pointer rounded-full border border-[#222222] bg-transparent px-2.5 py-1.5 font-inter text-[1rem] text-[#888888] transition-colors hover:border-white/30 focus:outline-none md:w-[17.5rem] md:min-w-[17.5rem] md:max-w-[17.5rem] md:px-5 md:py-2.5 md:text-[1.35rem] data-[filter-active=true]:border-white data-[filter-active=true]:bg-white data-[filter-active=true]:text-black"
          >
            <option value="">{t(locale, 'filter.client')}</option>
            {clients.map((client) => (
              <option value={client.value}>{client.label}</option>
            ))}
          </select>
        )
      }

      {
        locations.length > 0 && (
          <select
            data-filter-location
            data-filter-active="false"
            class="w-full min-w-0 cursor-pointer rounded-full border border-[#222222] bg-transparent px-2.5 py-1.5 font-inter text-[1rem] text-[#888888] transition-colors hover:border-white/30 focus:outline-none md:w-[15.5rem] md:min-w-[15.5rem] md:max-w-[15.5rem] md:px-5 md:py-2.5 md:text-[1.35rem] data-[filter-active=true]:border-white data-[filter-active=true]:bg-white data-[filter-active=true]:text-black"
          >
            <option value="">{t(locale, 'filter.location')}</option>
            {locations.map((location) => (
              <option value={location.value}>{location.label}</option>
            ))}
          </select>
        )
      }

      {
        years.length > 0 && (
          <select
            data-filter-year
            data-filter-active="false"
            class="w-full min-w-0 cursor-pointer rounded-full border border-[#222222] bg-transparent px-2.5 py-1.5 font-inter text-[1rem] text-[#888888] transition-colors hover:border-white/30 focus:outline-none md:w-[10.5rem] md:min-w-[10.5rem] md:max-w-[10.5rem] md:px-5 md:py-2.5 md:text-[1.35rem] data-[filter-active=true]:border-white data-[filter-active=true]:bg-white data-[filter-active=true]:text-black"
          >
            <option value="">{t(locale, 'filter.year')}</option>
            {years.map((year) => (
              <option value={year.value}>{year.label}</option>
            ))}
          </select>
        )
      }

      <button
        type="button"
        data-filter-clear
        hidden
        class="inline-flex w-fit shrink-0 cursor-pointer rounded-full border border-[#222222] bg-transparent px-2.5 py-1.5 font-inter text-[1rem] text-[#888888] transition-colors hover:border-white/30 md:px-5 md:py-2.5 md:text-[1.35rem]"
      >
        <span class="inline-flex items-center gap-1.5">
          <span aria-hidden="true">×</span>
          <span>{t(locale, 'filter.clear')}</span>
        </span>
      </button>
    </div>
  </div>
</div>
