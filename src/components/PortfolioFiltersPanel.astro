---
import type { FilterOption } from '~/lib/portfolio-filters'
import { projectCountLabel, t, type Locale } from '~/i18n'

interface Props {
  locale: Locale
  totalCount: number
  subcategories: FilterOption[]
  years: FilterOption[]
  locations: FilterOption[]
  clients: FilterOption[]
}

const { locale, totalCount, subcategories, years, locations, clients } = Astro.props
---

<div
  id="portfolio-filters-panel"
  data-filter-panel
  class="grid w-full grid-cols-4 gap-1.5 md:flex md:flex-wrap md:items-center md:gap-2.5 lg:flex-nowrap"
>
  {
    subcategories.length > 0 && (
      <select
        data-filter-category
        class="w-full min-w-0 cursor-pointer rounded-full border border-[#222222] bg-transparent px-2.5 py-1.5 font-inter text-[1rem] text-[#888888] transition-colors hover:border-white/30 focus:outline-none md:w-[15.5rem] md:min-w-[15.5rem] md:max-w-[15.5rem] md:px-5 md:py-2.5 md:text-[1.35rem]"
      >
        <option value="">{locale === 'cs' ? 'Kategorie' : 'Category'}</option>
        {subcategories.map((subcategory) => (
          <option value={subcategory.value}>{subcategory.label}</option>
        ))}
      </select>
    )
  }

  {
    clients.length > 0 && (
      <select
        data-filter-client
        class="w-full min-w-0 cursor-pointer rounded-full border border-[#222222] bg-transparent px-2.5 py-1.5 font-inter text-[1rem] text-[#888888] transition-colors hover:border-white/30 focus:outline-none md:w-[17.5rem] md:min-w-[17.5rem] md:max-w-[17.5rem] md:px-5 md:py-2.5 md:text-[1.35rem]"
      >
        <option value="">{t(locale, 'filter.client')}</option>
        {clients.map((client) => (
          <option value={client.value}>{client.label}</option>
        ))}
      </select>
    )
  }

  {
    locations.length > 0 && (
      <select
        data-filter-location
        class="w-full min-w-0 cursor-pointer rounded-full border border-[#222222] bg-transparent px-2.5 py-1.5 font-inter text-[1rem] text-[#888888] transition-colors hover:border-white/30 focus:outline-none md:w-[15.5rem] md:min-w-[15.5rem] md:max-w-[15.5rem] md:px-5 md:py-2.5 md:text-[1.35rem]"
      >
        <option value="">{t(locale, 'filter.location')}</option>
        {locations.map((location) => (
          <option value={location.value}>{location.label}</option>
        ))}
      </select>
    )
  }

  {
    years.length > 0 && (
      <select
        data-filter-year
        class="w-full min-w-0 cursor-pointer rounded-full border border-[#222222] bg-transparent px-2.5 py-1.5 font-inter text-[1rem] text-[#888888] transition-colors hover:border-white/30 focus:outline-none md:w-[10.5rem] md:min-w-[10.5rem] md:max-w-[10.5rem] md:px-5 md:py-2.5 md:text-[1.35rem]"
      >
        <option value="">{t(locale, 'filter.year')}</option>
        {years.map((year) => (
          <option value={year.value}>{year.label}</option>
        ))}
      </select>
    )
  }

  <div class="col-span-4 mt-3 flex w-full items-center justify-between md:mt-1 md:w-full md:justify-between md:gap-2.5 lg:mt-0 lg:ml-auto lg:w-auto lg:justify-end">
    <span class="font-geist text-[1.2rem] text-[#888888] md:text-[1.35rem]">
      <span
        data-filter-result-count
        data-locale={locale}
        data-label-one={t(locale, 'filter.project.one')}
        data-label-few={t(locale, 'filter.project.few')}
        data-label-other={t(locale, 'filter.project.other')}
      >
        {totalCount}
      </span>{' '}
      <span data-filter-result-label>{projectCountLabel(locale, totalCount)}</span>
    </span>

    <button
      type="button"
      data-filter-clear
      hidden
      class="inline-flex shrink-0 cursor-pointer rounded-full border border-[#222222] bg-transparent px-2.5 py-1.5 font-inter text-[1rem] text-[#555555] transition-colors hover:border-white/30 hover:text-white md:px-5 md:py-2.5 md:text-[1.35rem]"
    >
      <span class="inline-flex items-center gap-1.5">
        <span aria-hidden="true">×</span>
        <span>{t(locale, 'filter.clear')}</span>
      </span>
    </button>
  </div>
</div>
