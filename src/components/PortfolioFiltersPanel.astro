---
import type { FilterOption } from '~/lib/portfolio-filters'
import { t, type Locale } from '~/i18n'

interface Props {
  locale: Locale
  subcategories: FilterOption[]
  years: FilterOption[]
  locations: FilterOption[]
  clients: FilterOption[]
}

const { locale, subcategories, years, locations, clients } = Astro.props
---

<div
  id="portfolio-filters-panel"
  data-filter-panel
  class="absolute right-0 top-full z-50 mt-2 hidden w-[min(92vw,38rem)] rounded-2xl border border-[#222222] bg-[#090909]/95 p-3 shadow-2xl"
>
  <div class="grid grid-cols-1 gap-2.5">
    {
      subcategories.length > 0 && (
        <label class="flex min-w-0 flex-col gap-1">
          <span class="px-1 font-geist text-[1rem] uppercase tracking-[0.07em] text-[#777777]">
            {locale === 'cs' ? 'Kategorie' : 'Category'}
          </span>
          <select
            data-filter-category
            class="w-full min-w-0 cursor-pointer rounded-lg border border-[#222222] bg-transparent px-3 py-2.5 font-inter text-[1.3rem] text-[#d6d6d8] transition-colors hover:border-white/30 focus:outline-none focus-visible:border-white/60"
          >
            <option value="">{locale === 'cs' ? 'Kategorie' : 'Category'}</option>
            {subcategories.map((subcategory) => (
              <option value={subcategory.value}>{subcategory.label}</option>
            ))}
          </select>
        </label>
      )
    }

    {
      years.length > 0 && (
        <label class="flex min-w-0 flex-col gap-1">
          <span class="px-1 font-geist text-[1rem] uppercase tracking-[0.07em] text-[#777777]">
            {t(locale, 'filter.year')}
          </span>
          <select
            data-filter-year
            class="w-full min-w-0 cursor-pointer rounded-lg border border-[#222222] bg-transparent px-3 py-2.5 font-inter text-[1.3rem] text-[#d6d6d8] transition-colors hover:border-white/30 focus:outline-none focus-visible:border-white/60"
          >
            <option value="">{t(locale, 'filter.year')}</option>
            {years.map((year) => (
              <option value={year.value}>{year.label}</option>
            ))}
          </select>
        </label>
      )
    }

    {
      locations.length > 0 && (
        <label class="flex min-w-0 flex-col gap-1">
          <span class="px-1 font-geist text-[1rem] uppercase tracking-[0.07em] text-[#777777]">
            {t(locale, 'filter.location')}
          </span>
          <select
            data-filter-location
            class="w-full min-w-0 cursor-pointer rounded-lg border border-[#222222] bg-transparent px-3 py-2.5 font-inter text-[1.3rem] text-[#d6d6d8] transition-colors hover:border-white/30 focus:outline-none focus-visible:border-white/60"
          >
            <option value="">{t(locale, 'filter.location')}</option>
            {locations.map((location) => (
              <option value={location.value}>{location.label}</option>
            ))}
          </select>
        </label>
      )
    }

    {
      clients.length > 0 && (
        <label class="flex min-w-0 flex-col gap-1">
          <span class="px-1 font-geist text-[1rem] uppercase tracking-[0.07em] text-[#777777]">
            {t(locale, 'filter.client')}
          </span>
          <select
            data-filter-client
            class="w-full min-w-0 cursor-pointer rounded-lg border border-[#222222] bg-transparent px-3 py-2.5 font-inter text-[1.3rem] text-[#d6d6d8] transition-colors hover:border-white/30 focus:outline-none focus-visible:border-white/60"
          >
            <option value="">{t(locale, 'filter.client')}</option>
            {clients.map((client) => (
              <option value={client.value}>{client.label}</option>
            ))}
          </select>
        </label>
      )
    }
  </div>

  <button
    type="button"
    data-filter-clear
    hidden
    class="mt-3 inline-flex w-fit shrink-0 cursor-pointer rounded-lg border border-[#222222] bg-transparent px-3 py-1.5 font-inter text-[1.2rem] text-[#555555] transition-colors hover:border-white/30 hover:text-white"
  >
    <span class="inline-flex items-center gap-1.5">
      <span aria-hidden="true">×</span>
      <span>{t(locale, 'filter.clear')}</span>
    </span>
  </button>
</div>
