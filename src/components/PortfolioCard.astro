---
import { Image } from '@datocms/astro'
import { localePath, type Locale } from '~/i18n'
import { portfolioCanonicalPath } from '~/i18n/routes'
import type { PortfolioListItem } from '~/api'

interface Props {
  portfolio: PortfolioListItem
  locale: Locale
}

const { portfolio, locale } = Astro.props

const thumb = portfolio.thumbnail
const responsiveImage = thumb?.responsiveImage
const transitionName = portfolio.id
  ? `portfolio-media-${portfolio.id}`
  : portfolio.slug
    ? `portfolio-media-${portfolio.slug}`
    : undefined

const firstSubcategory = portfolio.subcategory?.[0]?.name || null
const location = portfolio.location || null
const chips = [firstSubcategory, location].filter(Boolean) as string[]
---

{
  responsiveImage && (
    <a
      href={localePath(locale, portfolioCanonicalPath(locale, portfolio.slug!))}
      class="portfolio-card group relative block w-full no-underline"
    >
      <div class="portfolio-card-frame relative overflow-hidden rounded-sm bg-black">
        <div
          class="portfolio-card-media"
          style={
            transitionName
              ? `view-transition-name:${transitionName}`
              : undefined
          }
        >
          <Image
            data={{
              ...responsiveImage,
              alt: '',
            }}
            pictureClass="w-full"
            imgClass="block h-auto w-full"
          />
        </div>
        <div class="portfolio-card-overlay pointer-events-none absolute inset-0" />

        {/* Title + chips overlaid on image */}
        <div class="pointer-events-none absolute inset-x-0 bottom-0 flex flex-col gap-2 p-4 md:p-5">
          <h3
            class="portfolio-card-title m-0 font-anton text-[2.2rem] uppercase leading-none text-white md:text-[2.8rem] lg:text-[3.4rem]"
            style="text-shadow: 0 2px 12px rgba(0,0,0,0.7), 0 1px 3px rgba(0,0,0,0.5);"
          >
            {portfolio.title}
          </h3>
          {chips.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
              {chips.map((chip) => (
                <span class="rounded-full bg-white/10 px-2.5 py-0.5 font-geist text-[1rem] text-white/80 backdrop-blur-md md:text-[1.1rem]">
                  {chip}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    </a>
  )
}
