---
import BaseLayout from '~/layouts/BaseLayout.astro'
import Page from '~/components/Page.astro'
import Header from '~/components/Header.astro'
import Section from '~/components/About/Section.astro'
import type { ResponsiveImage } from '~/api/generated/types'
import type { Locale } from '~/i18n'
import { t } from '~/i18n'

interface Props {
  locale: Locale
  canonicalPath: string
  hreflangPaths: { en: string; cs: string }
  switchHref: string
  headerBackground: ResponsiveImage
}

const { locale, canonicalPath, hreflangPaths, switchHref, headerBackground } =
  Astro.props
---

<BaseLayout
  title={`${t(locale, 'nav.about')} - ${t(locale, 'meta.title')}`}
  locale={locale}
  canonicalPath={canonicalPath}
  hreflangPaths={hreflangPaths}
>
  <Page isAboutPage locale={locale}>
    <Header
      slot="header"
      title={t(locale, 'nav.about')}
      headerBackground={headerBackground}
      isAboutPage
      currentPath={`/${locale}${canonicalPath}`}
      locale={locale}
      pagePath={canonicalPath}
      switchHref={switchHref}
    />
    <Section title="Cool numbers">
      <ul class="m-0 list-none p-0 md:flex md:justify-around">
        <li class="flex-1">
          <h3
            class="font-anton text-[2rem] uppercase text-[#49494b] md:text-[3rem] lg:text-[4rem]"
          >
            <strong
              class="block text-[6rem] leading-none text-white sm:text-[7rem] sm:leading-tight md:text-[8rem] lg:text-[10rem] lg:leading-snug xl:text-[12rem]"
            >
              135
            </strong>
            Projects
          </h3>
        </li>
        <li class="flex-1">
          <h3
            class="font-anton text-[2rem] uppercase text-[#49494b] md:text-[3rem] lg:text-[4rem]"
          >
            <strong
              class="block text-[6rem] leading-none text-white sm:text-[7rem] sm:leading-tight md:text-[8rem] lg:text-[10rem] lg:leading-snug xl:text-[12rem]"
            >
              22
            </strong>
            Different countries
          </h3>
        </li>
        <li class="flex-1">
          <h3
            class="font-anton text-[2rem] uppercase text-[#49494b] md:text-[3rem] lg:text-[4rem]"
          >
            <strong
              class="block text-[6rem] leading-none text-white sm:text-[7rem] sm:leading-tight md:text-[8rem] lg:text-[10rem] lg:leading-snug xl:text-[12rem]"
            >
              800+
            </strong>
            Flight hours
          </h3>
        </li>
      </ul>
    </Section>
    <Section title="I can help with" gray>
      <ul class="m-0 list-none p-0">
        <li
          class="my-[10px] py-[10px] font-anton text-[3rem] font-semibold uppercase leading-none text-secondary transition-colors duration-200 hover:text-white md:text-[4rem]"
        >
          Documentary
        </li>
        <li
          class="my-[10px] py-[10px] font-anton text-[3rem] font-semibold uppercase leading-none text-secondary transition-colors duration-200 hover:text-white md:text-[4rem]"
        >
          Film
        </li>
        <li
          class="my-[10px] py-[10px] font-anton text-[3rem] font-semibold uppercase leading-none text-secondary transition-colors duration-200 hover:text-white md:text-[4rem]"
        >
          Commercial promo
        </li>
        <li
          class="my-[10px] py-[10px] font-anton text-[3rem] font-semibold uppercase leading-none text-secondary transition-colors duration-200 hover:text-white md:text-[4rem]"
        >
          Architecture
        </li>
        <li
          class="my-[10px] py-[10px] font-anton text-[3rem] font-semibold uppercase leading-none text-secondary transition-colors duration-200 hover:text-white md:text-[4rem]"
        >
          Music video
        </li>
      </ul>
    </Section>
    <Section title="Tech specs">
      <ul class="m-0 list-none p-0 md:flex md:justify-around">
        <li class="flex-1">
          <h3
            class="font-anton text-[2rem] uppercase text-[#49494b] md:text-[3rem] lg:text-[4rem]"
          >
            <strong
              class="block text-[6rem] leading-none text-white sm:text-[7rem] sm:leading-tight md:text-[8rem] lg:text-[10rem] lg:leading-snug xl:text-[12rem]"
            >
              4K/60<span class="text-[5rem]">FPS</span>
            </strong>
            AERIAL VIDEO
          </h3>
        </li>
        <li class="flex-1">
          <h3
            class="font-anton text-[2rem] uppercase text-[#49494b] md:text-[3rem] lg:text-[4rem]"
          >
            <strong
              class="block text-[6rem] leading-none text-white sm:text-[7rem] sm:leading-tight md:text-[8rem] lg:text-[10rem] lg:leading-snug xl:text-[12rem]"
            >
              20<span class="text-[5rem]">MPX</span>
            </strong>
            AERIAL PHOTOGRAPHY
          </h3>
        </li>
        <li class="flex-1">
          <h3
            class="font-anton text-[2rem] uppercase text-[#49494b] md:text-[3rem] lg:text-[4rem]"
          >
            <strong
              class="block text-[6rem] leading-none text-white sm:text-[7rem] sm:leading-tight md:text-[8rem] lg:text-[10rem] lg:leading-snug xl:text-[12rem]"
            >
              162<span class="text-[5rem]">MPX</span>
            </strong>
            360° PHOTOGRAPHY
          </h3>
        </li>
      </ul>
    </Section>
    <Section title={t(locale, 'about.credentials.title')}>
      <div class="mx-auto max-w-[420px] text-secondary">
        <h3
          class="my-[2em] mt-[25px] font-anton text-[4rem] font-semibold uppercase text-white"
        >
          {t(locale, 'about.credentials.personName')}
        </h3>
        {t(locale, 'about.credentials.phoneLabel')}{' '}
        <a href="tel:+420773604400" class="text-secondary no-underline">
          +420 773 604 400
        </a>
        <br />
        <a
          href="mailto:info@ondrahajek.com"
          class="text-secondary no-underline"
        >
          info@ondrahajek.com
        </a>
        <br />
        <br />
        <h3
          class="my-[2em] mt-[25px] font-anton text-[4rem] font-semibold uppercase text-white"
        >
          {t(locale, 'about.credentials.companyName')}
        </h3>
        {t(locale, 'about.credentials.licenseText')}
        <br />
        <br />
        {t(locale, 'about.credentials.icoLabel')}: {t(locale, 'about.credentials.icoValue')}
        <br />
        {t(locale, 'about.credentials.dicLabel')}: {t(locale, 'about.credentials.dicValue')}
      </div>
    </Section>
  </Page>
</BaseLayout>
