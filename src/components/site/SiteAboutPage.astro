---
import BaseLayout from '~/layouts/BaseLayout.astro'
import Page from '~/components/Page.astro'
import Header from '~/components/Header.astro'
import Section from '~/components/About/Section.astro'
import type { ResponsiveImage } from '~/api/generated/types'
import type { Locale } from '~/i18n'
import { t } from '~/i18n'
import { localizedPagePath } from '~/i18n/routes'
import type { AboutHelpLinkItem } from '~/lib/about-help-links'
import { CONTACT_EMAIL, CONTACT_PHONE } from '~/config'

interface Props {
  locale: Locale
  canonicalPath: string
  hreflangPaths: { en: string; cs: string }
  switchHref: string
  headerBackground: ResponsiveImage
  helpLinks: AboutHelpLinkItem[]
}

const {
  locale,
  canonicalPath,
  hreflangPaths,
  switchHref,
  headerBackground,
  helpLinks,
} = Astro.props

const PERSON_NAME = 'ONDŘEJ HÁJEK'
const COMPANY_NAME = 'COPTER Vision s.r.o.'
const COMPANY_ICO = '03813452'
const COMPANY_DIC = 'CZ03813452'
const fallbackLinks: AboutHelpLinkItem[] = [
  { label: 'Documentary', subSlug: 'documentary', targetPage: 'drone' },
  { label: 'Film', subSlug: 'film-production', targetPage: 'drone' },
  {
    label: 'Commercial & Promo',
    subSlug: 'creative-campaign',
    targetPage: 'drone',
  },
  { label: 'Architecture', subSlug: 'architecture', targetPage: 'drone' },
  { label: 'Interview', subSlug: 'interview', targetPage: 'video' },
]
const linksToRender = helpLinks.length > 0 ? helpLinks : fallbackLinks
---

<BaseLayout
  title={`${t(locale, 'nav.about')} - ${t(locale, 'meta.title')}`}
  locale={locale}
  canonicalPath={canonicalPath}
  hreflangPaths={hreflangPaths}
>
  <Page isAboutPage locale={locale} switchUrl={switchHref}>
    <Header
      slot="header"
      title={t(locale, 'nav.about')}
      headerBackground={headerBackground}
      isAboutPage
    >
      <div slot="aboutOverlay" class="mx-auto max-w-[620px] text-secondary">
        <h2
          class="m-0 mb-5 font-anton text-[5rem] font-semibold leading-[0.95] text-white md:text-[6rem]"
        >
          {PERSON_NAME}
        </h2>
        <p class="m-0 text-[2rem] leading-[1.4] md:text-[3.2rem]">
          {t(locale, 'about.credentials.phoneLabel')}{' '}
          <a href={`tel:${CONTACT_PHONE.replace(/\s/g, '')}`} class="text-secondary no-underline">
            {CONTACT_PHONE}
          </a>
          <br />
          <a
            href={`mailto:${CONTACT_EMAIL}`}
            class="text-secondary no-underline"
          >
            {CONTACT_EMAIL}
          </a>
        </p>
        <h2
          class="m-0 mb-5 mt-12 font-anton text-[5rem] font-semibold leading-[0.95] text-white md:text-[6rem]"
        >
          {COMPANY_NAME}
        </h2>
        <p class="m-0 text-[2rem] leading-[1.45] md:text-[3.2rem]">
          {t(locale, 'about.credentials.licenseText')}
          <br />
          <br />
          ICO: {COMPANY_ICO}
          <br />
          DIC: {COMPANY_DIC}
        </p>
      </div>
    </Header>
    <Section title="I can help with" gray>
      <ul class="m-0 list-none p-0">
        {
          linksToRender.map((item) => {
            const targetPath = localizedPagePath(locale, item.targetPage)
            const href = `/${locale}${targetPath}?sub=${encodeURIComponent(item.subSlug)}`
            return (
              <li class="my-[10px] py-[10px]">
                <a
                  href={href}
                  class="font-anton text-[3rem] font-semibold uppercase leading-none text-secondary no-underline transition-colors duration-200 hover:text-white focus-visible:text-white md:text-[4rem]"
                >
                  {item.label}
                </a>
              </li>
            )
          })
        }
      </ul>
    </Section>
  </Page>
</BaseLayout>
