---
import BaseLayout from '~/layouts/BaseLayout.astro'
import Page from '~/components/Page.astro'
import Header from '~/components/Header.astro'
import Section from '~/components/About/Section.astro'
import type { ResponsiveImage } from '~/api/generated/types'
import type { Locale } from '~/i18n'
import { t } from '~/i18n'

interface Props {
  locale: Locale
  canonicalPath: string
  hreflangPaths: { en: string; cs: string }
  switchHref: string
  headerBackground: ResponsiveImage
}

const { locale, canonicalPath, hreflangPaths, switchHref, headerBackground } =
  Astro.props

const PERSON_NAME = 'ONDŘEJ HÁJEK'
const COMPANY_NAME = 'COPTER VISION S.R.O.'
const COMPANY_ICO = '03813452'
const COMPANY_DIC = 'CZ03813452'
---

<BaseLayout
  title={`${t(locale, 'nav.about')} - ${t(locale, 'meta.title')}`}
  locale={locale}
  canonicalPath={canonicalPath}
  hreflangPaths={hreflangPaths}
>
  <Page isAboutPage locale={locale}>
    <Header
      slot="header"
      title={t(locale, 'nav.about')}
      headerBackground={headerBackground}
      isAboutPage
      currentPath={`/${locale}${canonicalPath}`}
      locale={locale}
      pagePath={canonicalPath}
      switchHref={switchHref}
    />
    <Section title="I can help with" gray>
      <ul class="m-0 list-none p-0">
        <li
          class="my-[10px] py-[10px] font-anton text-[3rem] font-semibold uppercase leading-none text-secondary transition-colors duration-200 hover:text-white md:text-[4rem]"
        >
          Documentary
        </li>
        <li
          class="my-[10px] py-[10px] font-anton text-[3rem] font-semibold uppercase leading-none text-secondary transition-colors duration-200 hover:text-white md:text-[4rem]"
        >
          Film
        </li>
        <li
          class="my-[10px] py-[10px] font-anton text-[3rem] font-semibold uppercase leading-none text-secondary transition-colors duration-200 hover:text-white md:text-[4rem]"
        >
          Commercial promo
        </li>
        <li
          class="my-[10px] py-[10px] font-anton text-[3rem] font-semibold uppercase leading-none text-secondary transition-colors duration-200 hover:text-white md:text-[4rem]"
        >
          Architecture
        </li>
        <li
          class="my-[10px] py-[10px] font-anton text-[3rem] font-semibold uppercase leading-none text-secondary transition-colors duration-200 hover:text-white md:text-[4rem]"
        >
          Music video
        </li>
      </ul>
    </Section>
    <Section title={t(locale, 'about.credentials.title')}>
      <div class="mx-auto max-w-[420px] text-secondary">
        <h3
          class="my-[2em] mt-[25px] font-anton text-[4rem] font-semibold uppercase text-white"
        >
          {PERSON_NAME}
        </h3>
        {t(locale, 'about.credentials.phoneLabel')}{' '}
        <a href="tel:+420773604400" class="text-secondary no-underline">
          +420 773 604 400
        </a>
        <br />
        <a
          href="mailto:info@ondrahajek.com"
          class="text-secondary no-underline"
        >
          info@ondrahajek.com
        </a>
        <br />
        <br />
        <h3
          class="my-[2em] mt-[25px] font-anton text-[4rem] font-semibold uppercase text-white"
        >
          {COMPANY_NAME}
        </h3>
        {t(locale, 'about.credentials.licenseText')}
        <br />
        <br />
        ICO: {COMPANY_ICO}
        <br />
        DIC: {COMPANY_DIC}
      </div>
    </Section>
  </Page>
</BaseLayout>
