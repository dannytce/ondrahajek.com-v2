---
import type { ResponsiveImage } from '~/api/generated/types'

interface Props {
  data: ResponsiveImage & { alt?: string }
  class?: string
  imgClass?: string
  priority?: boolean
  sizes?: string
  layout?: 'intrinsic' | 'fixed' | 'responsive' | 'fill'
  objectFit?: string
  objectPosition?: string
}

const {
  data,
  class: className,
  imgClass,
  priority = false,
  sizes,
  layout = 'responsive',
  objectFit,
  objectPosition,
} = Astro.props

const placeholderStyle = data.base64
  ? [
      `background-image:url("${data.base64}")`,
      'background-size:cover',
      'background-repeat:no-repeat',
      'background-position:50% 50%',
      'color:transparent',
    ].join(';')
  : data.bgColor
    ? [`background-color:${data.bgColor}`, 'color:transparent'].join(';')
    : ''

const imageStyle = [
  layout === 'fill' ? 'width:100%;height:100%' : 'width:100%;height:auto',
  objectFit ? `object-fit:${objectFit}` : '',
  objectPosition ? `object-position:${objectPosition}` : '',
  placeholderStyle,
]
  .filter(Boolean)
  .join(';')
---

<picture class={className}>
  {
    data.webpSrcSet && (
      <source
        type="image/webp"
        srcset={data.webpSrcSet}
        sizes={sizes ?? data.sizes ?? undefined}
      />
    )
  }
  {
    data.srcSet && (
      <source srcset={data.srcSet} sizes={sizes ?? data.sizes ?? undefined} />
    )
  }
  <img
    src={data.src ?? undefined}
    srcset={data.srcSet ?? undefined}
    sizes={sizes ?? data.sizes ?? undefined}
    width={layout === 'fill' ? undefined : (data.width ?? undefined)}
    height={layout === 'fill' ? undefined : (data.height ?? undefined)}
    alt={data.alt ?? ''}
    title={data.title ?? undefined}
    class={imgClass}
    style={imageStyle}
    loading={priority ? 'eager' : 'lazy'}
    decoding="async"
    referrerpolicy="no-referrer-when-downgrade"
  />
</picture>
