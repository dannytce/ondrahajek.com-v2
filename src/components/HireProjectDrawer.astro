---
import { t, type Locale } from '~/i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const email = 'info@ondrahajek.com'
const phone = '+420 773 604 400'
const telHref = `tel:${phone.replace(/\s/g, '')}`
---

<div class="pointer-events-none fixed bottom-0 right-0 z-modal p-4 md:p-6">
  <button
    type="button"
    data-hire-open
    class="pointer-events-auto rounded-full border border-white/25 bg-[#111114]/95 px-5 py-3 font-anton text-[1.6rem] uppercase tracking-wide text-white shadow-lg backdrop-blur transition-colors hover:border-white/50 hover:bg-[#17171a]"
  >
    {t(locale, 'hire.open')}
  </button>
</div>

<dialog
  data-hire-dialog
  class="hire-dialog z-modal m-0 ml-auto h-full max-h-full w-[min(100vw,420px)] max-w-full border-0 bg-[#0a0a0c] p-0 text-white shadow-2xl backdrop:bg-black/60"
>
  <div class="flex h-full flex-col border-l border-white/10">
    <div
      class="flex items-center justify-between border-b border-white/10 px-6 py-4"
    >
      <h2 class="m-0 font-anton text-[2.4rem] uppercase tracking-wide">
        {t(locale, 'hire.title')}
      </h2>
      <button
        type="button"
        data-hire-close
        class="rounded border border-white/20 px-3 py-1 font-anton text-[1.4rem] uppercase text-secondary transition-colors hover:border-white/40 hover:text-white"
        aria-label={t(locale, 'hire.close')}
      >
        {t(locale, 'hire.close')}
      </button>
    </div>
    <div class="flex flex-1 flex-col gap-8 overflow-y-auto px-6 py-8">
      <p class="m-0 font-inter text-[1.6rem] leading-relaxed text-secondary">
        {t(locale, 'hire.body')}
      </p>
      <div class="flex flex-col gap-4">
        <div>
          <p class="m-0 mb-1 font-inter text-[1.3rem] text-secondary">
            {t(locale, 'hire.emailLabel')}
          </p>
          <a
            href={`mailto:${email}`}
            class="break-all font-anton text-[2rem] uppercase text-white no-underline transition-colors hover:text-primary"
          >
            {email}
          </a>
        </div>
        <div>
          <p class="m-0 mb-1 font-inter text-[1.3rem] text-secondary">
            {t(locale, 'hire.phoneLabel')}
          </p>
          <a
            href={telHref}
            class="font-anton text-[2rem] uppercase text-white no-underline transition-colors hover:text-primary"
          >
            {phone}
          </a>
        </div>
      </div>
    </div>
  </div>
</dialog>

<script>
  document.addEventListener('click', (e) => {
    const t = e.target
    if (!(t instanceof Element)) return
    const dialog = document.querySelector(
      '[data-hire-dialog]'
    ) as HTMLDialogElement | null
    if (!dialog) return
    if (t.closest('[data-hire-open]')) {
      e.preventDefault()
      if (!dialog.open) dialog.showModal()
      return
    }
    if (t.closest('[data-hire-close]')) {
      dialog.close()
      return
    }
    if (e.target === dialog) dialog.close()
  })
</script>

<style>
  .hire-dialog::backdrop {
    background: rgba(0, 0, 0, 0.55);
  }
  .hire-dialog[open] {
    display: flex;
  }
</style>
