---
import { t, type Locale } from '~/i18n'
import { SOCIAL_LINKS } from '~/config/social'

interface NavLink {
  text: string
  link: string
}

interface Props {
  locale: Locale
  navLinks: NavLink[]
}

const { locale, navLinks } = Astro.props
---

<div
  data-mobile-menu
  class="pointer-events-none fixed inset-0 z-[99] opacity-0 transition-opacity duration-300"
>
  <div class="absolute inset-0 bg-[#0A0A0A]/95 backdrop-blur-sm"></div>
  <div class="relative flex h-full flex-col px-5 pb-10 pt-16">
    <nav class="flex flex-1 flex-col justify-start gap-0 pt-8">
      {
        navLinks.map((item) => (
          <a
            href={item.link}
            data-mobile-menu-link
            class="flex items-center justify-between border-b border-white/10 py-5 font-anton text-[3.4rem] leading-[0.92] tracking-[0.005em] text-white no-underline transition-colors hover:text-[#4A9FD8]"
          >
            <span>{item.text}</span>
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="text-foreground-dim"
            >
              <path d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </a>
        ))
      }
    </nav>

    <div class="flex flex-col gap-6 pt-8">
      <div class="flex items-center justify-between">
        <div class="flex flex-col gap-1">
          <span
            class="font-geist text-[1rem] uppercase tracking-widest text-foreground-dim"
          >
            {locale === 'cs' ? 'KONTAKTUJTE NÁS' : 'GET IN TOUCH'}
          </span>
          <a
            href="mailto:info@ondrahajek.com"
            class="font-inter text-[1.4rem] text-accent-primary no-underline transition-colors hover:text-white"
          >
            info@ondrahajek.com
          </a>
          <a
            href="tel:+420773604400"
            class="font-inter text-[1.3rem] text-foreground-muted no-underline transition-colors hover:text-white"
          >
            +420 773 604 400
          </a>
        </div>
      </div>
      <div class="flex gap-2">
        <a
          href={SOCIAL_LINKS.linkedin}
          target="_blank"
          rel="noopener"
          class="rounded-full border border-border-subtle px-4 py-2 font-geist text-[1.1rem] text-foreground-muted no-underline transition-colors hover:border-white/40 hover:text-white"
        >
          LinkedIn
        </a>
        <a
          href={SOCIAL_LINKS.instagram}
          target="_blank"
          rel="noopener"
          class="rounded-full border border-border-subtle px-4 py-2 font-geist text-[1.1rem] text-foreground-muted no-underline transition-colors hover:border-white/40 hover:text-white"
        >
          Instagram
        </a>
        <a
          href={SOCIAL_LINKS.vimeo}
          target="_blank"
          rel="noopener"
          class="rounded-full border border-border-subtle px-4 py-2 font-geist text-[1.1rem] text-foreground-muted no-underline transition-colors hover:border-white/40 hover:text-white"
        >
          Vimeo
        </a>
      </div>
    </div>
  </div>
</div>
