---
import LanguageToggle from './LanguageToggle.astro'
import { t, type Locale } from '~/i18n'

interface NavLink {
  text: string
  link: string
}

interface Props {
  locale: Locale
  switchUrl: string
  navLinks: NavLink[]
}

const { locale, switchUrl, navLinks } = Astro.props
---

<div
  data-mobile-menu
  class="pointer-events-none fixed inset-0 z-[99] opacity-0 transition-opacity duration-300"
>
  <div class="absolute inset-0 bg-surface-dark/98 backdrop-blur-sm"></div>
  <div class="relative flex h-full flex-col px-8 pb-12 pt-28">
    <nav class="flex flex-1 flex-col justify-center gap-1">
      {navLinks.map((item) => (
        <a
          href={item.link}
          data-mobile-menu-link
          class="flex items-center justify-between border-b border-border-subtle py-5 font-anton text-[3.2rem] uppercase leading-tight text-white no-underline transition-colors hover:text-accent-primary"
        >
          <span>{item.text}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-foreground-dim">
            <path d="M7 17L17 7M17 7H7M17 7V17" />
          </svg>
        </a>
      ))}
    </nav>

    <div class="flex flex-col gap-6 pt-8">
      <div class="flex items-center justify-between">
        <div class="flex flex-col gap-1">
          <span class="font-geist text-[1rem] uppercase tracking-widest text-foreground-dim">
            {locale === 'cs' ? 'KONTAKTUJTE NÁS' : 'GET IN TOUCH'}
          </span>
          <a href="mailto:info@ondrahajek.com" class="font-inter text-[1.4rem] text-accent-primary no-underline transition-colors hover:text-white">
            info@ondrahajek.com
          </a>
          <a href="tel:+420773604400" class="font-inter text-[1.3rem] text-foreground-muted no-underline transition-colors hover:text-white">
            +420 777 XXX XXX
          </a>
        </div>
        <LanguageToggle locale={locale} switchUrl={switchUrl} />
      </div>
      <div class="flex gap-2">
        <a href="https://www.linkedin.com/in/ondrahajek/" target="_blank" rel="noopener" class="rounded-full border border-border-subtle px-4 py-2 font-geist text-[1.1rem] text-foreground-muted no-underline transition-colors hover:border-white/40 hover:text-white">
          LinkedIn
        </a>
        <a href="https://www.instagram.com/ondrahajek.drone/" target="_blank" rel="noopener" class="rounded-full border border-border-subtle px-4 py-2 font-geist text-[1.1rem] text-foreground-muted no-underline transition-colors hover:border-white/40 hover:text-white">
          Instagram
        </a>
        <a href="https://vimeo.com/ondrahajek" target="_blank" rel="noopener" class="rounded-full border border-border-subtle px-4 py-2 font-geist text-[1.1rem] text-foreground-muted no-underline transition-colors hover:border-white/40 hover:text-white">
          Vimeo
        </a>
      </div>
    </div>
  </div>
</div>
