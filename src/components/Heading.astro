---
import {
  headingTypeClass,
  type HeadingLevel,
  type HeadingSize,
} from '~/lib/heading-variants'

interface Props {
  level: HeadingLevel
  size: HeadingSize
  class?: string
}

const { level, size, class: extraClass } = Astro.props

const cls = [headingTypeClass(size), extraClass]
---

{
  level === 1 && (
    <h1 class:list={cls}>
      <slot />
    </h1>
  )
}
{
  level === 2 && (
    <h2 class:list={cls}>
      <slot />
    </h2>
  )
}
{
  level === 3 && (
    <h3 class:list={cls}>
      <slot />
    </h3>
  )
}
{
  level === 4 && (
    <h4 class:list={cls}>
      <slot />
    </h4>
  )
}
