---
import DatoImage from './DatoImage.astro';
import type { FileField } from '~/api/generated/types';

interface Props {
  photos: FileField[];
}

const { photos } = Astro.props;
---

<div class="w-full max-w-container mx-auto px-[15px] xl:px-0 max-w-[1077px]">
  {photos.map((item) => (
    <figure class="mt-[50px] mb-0">
      <DatoImage
        data={{
          ...item.responsiveImage!,
          alt: Array.isArray(item.smartTags) ? item.smartTags.filter(Boolean).join(', ') : '',
        }}
      />
      <figcaption class="text-[3rem] sm:text-[3.4rem] md:text-[3.8rem] lg:text-[4rem] font-teko text-primary -mt-[0.45em] ml-5 leading-none uppercase relative z-10">
        {item.title}
      </figcaption>
      <span class="text-secondary text-[1.6rem] md:text-[1.8rem] ml-5">
        {item.alt}
      </span>
    </figure>
  ))}
</div>
