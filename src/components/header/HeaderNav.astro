---
import LanguageToggle from '~/components/LanguageToggle.astro'
import MobileMenuOverlay from '~/components/MobileMenuOverlay.astro'
import { localePath, type Locale } from '~/i18n'

interface NavLink {
  text: string
  link: string
}

interface Props {
  locale: Locale
  currentPath: string
  switchUrl: string
  navLinks: NavLink[]
}

const { locale, currentPath, switchUrl, navLinks } = Astro.props
---

<div
  data-site-nav
  data-visible="true"
  class="site-nav fixed left-0 right-0 top-0 z-nav"
>
  <div class="site-nav-bg absolute inset-0 bg-surface-dark/90 backdrop-blur-md border-b border-white/5"></div>
  <nav class="relative mx-auto flex h-20 w-full max-w-container items-center justify-between px-[15px] xl:px-0">
    <a href={localePath(locale, '/')} class="flex items-center">
      <img src="/logo-ondrahajek.svg" alt="ONDRAHAJEK.COM" class="h-5" />
    </a>

    {/* Desktop nav links */}
    <div class="hidden items-center gap-8 md:flex">
      {navLinks.map((item) => (
        <a
          href={item.link}
          class:list={[
            'font-inter text-[1.3rem] uppercase tracking-wider text-foreground-muted no-underline transition-colors hover:text-white',
            currentPath === item.link && 'text-white',
          ]}
        >
          {item.text}
        </a>
      ))}
      <LanguageToggle locale={locale} switchUrl={switchUrl} />
    </div>

    {/* Mobile hamburger button */}
    <button
      data-mobile-menu-toggle
      class="relative z-[100] flex h-10 w-10 flex-col items-center justify-center gap-[5px] md:hidden"
      aria-label="Toggle menu"
    >
      <span class="hamburger-line block h-[2px] w-5 bg-white transition-all duration-300"></span>
      <span class="hamburger-line block h-[2px] w-5 bg-white transition-all duration-300"></span>
    </button>
  </nav>
</div>

<MobileMenuOverlay locale={locale} switchUrl={switchUrl} navLinks={navLinks} />

<style>
  [data-site-nav] {
    transition: transform 300ms ease-out, opacity 300ms ease-out;
  }

  [data-site-nav][data-visible='false'] {
    transform: translateY(-100%);
    opacity: 0;
  }

  [data-site-nav][data-visible='true'] {
    transform: translateY(0);
    opacity: 1;
  }

  /* Hamburger → X animation */
  [data-mobile-menu-toggle][aria-expanded='true'] .hamburger-line:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }

  [data-mobile-menu-toggle][aria-expanded='true'] .hamburger-line:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }
</style>
