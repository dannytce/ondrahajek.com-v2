---
import LanguageToggle from '~/components/LanguageToggle.astro'
import MobileMenuOverlay from '~/components/MobileMenuOverlay.astro'
import { localePath, t, type Locale } from '~/i18n'

interface NavLink {
  text: string
  link: string
}

interface Props {
  locale: Locale
  currentPath: string
  switchUrl: string
  navLinks: NavLink[]
}

const { locale, currentPath, switchUrl, navLinks } = Astro.props
---

<div
  data-site-nav
  data-visible="true"
  class="site-nav fixed inset-x-0 top-0 z-nav w-full border-b border-white/10 bg-black/30 pt-[env(safe-area-inset-top)] backdrop-blur-md backdrop-saturate-150 supports-[backdrop-filter]:bg-black/25"
>
  <div
    class="mx-auto flex h-14 w-full max-w-container items-center justify-between gap-4 px-[15px] md:h-16"
  >
    <a
      href={localePath(locale, '/')}
      class="pointer-events-auto flex shrink-0 items-center text-white no-underline"
      aria-label={t(locale, 'header.homepageAriaLabel')}
    >
      <img
        src="/logo-ondrahajek.svg"
        alt="ONDRAHAJEK.COM"
        width="137"
        height="13"
        class="h-5 w-auto"
      />
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <ul class="m-0 flex list-none items-center gap-6 p-0 lg:gap-8">
        {
          navLinks.map((item) => (
            <li class="m-0 p-0">
              <a
                href={item.link}
                class:list={[
                  'nav-header-link pointer-events-auto flex items-center text-right font-teko text-[2rem] font-normal uppercase leading-none no-underline',
                  currentPath === item.link && 'is-active',
                ]}
              >
                {item.text}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="pointer-events-auto">
        <LanguageToggle locale={locale} switchUrl={switchUrl} />
      </div>
    </div>

    <div class="flex items-center gap-2 md:hidden">
      <div class="pointer-events-auto">
        <LanguageToggle
          locale={locale}
          switchUrl={switchUrl}
          class="scale-90 border-white/25 text-[1rem]"
        />
      </div>
      <button
        data-mobile-menu-toggle
        class="pointer-events-auto relative z-[100] flex h-10 w-10 flex-col items-center justify-center gap-[5px]"
        aria-label={t(locale, 'header.menuToggleAriaLabel')}
      >
        <span
          class="hamburger-line block h-[2px] w-5 bg-white transition-all duration-300"
        ></span>
        <span
          class="hamburger-line block h-[2px] w-5 bg-white transition-all duration-300"
        ></span>
      </button>
    </div>
  </div>
</div>

<MobileMenuOverlay locale={locale} navLinks={navLinks} />

<style>
  /* Legacy ondrahajek.com /about: gradient text + sweep (Teko nav) */
  .nav-header-link {
    padding-top: 0.1em;
    background: linear-gradient(to right, #ddd, #ddd 50%, #fff 50%);
    background-size: 200% 100%;
    background-position: 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: background-position 275ms ease;
  }

  .nav-header-link:hover,
  .nav-header-link.is-active {
    background-position: 0 100%;
  }

  [data-site-nav] {
    transition:
      transform 300ms ease-out,
      opacity 300ms ease-out;
  }

  [data-site-nav][data-visible='false'] {
    transform: translateY(-100%);
    opacity: 0;
  }

  [data-site-nav][data-visible='true'] {
    transform: translateY(0);
    opacity: 1;
  }

  [data-mobile-menu-toggle][aria-expanded='true'] .hamburger-line:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }

  [data-mobile-menu-toggle][aria-expanded='true'] .hamburger-line:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }
</style>
