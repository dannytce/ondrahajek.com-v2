---
import LanguageToggle from '~/components/LanguageToggle.astro'
import MobileMenuOverlay from '~/components/MobileMenuOverlay.astro'
import { localePath, t, type Locale } from '~/i18n'

interface NavLink {
  text: string
  link: string
}

interface Props {
  locale: Locale
  currentPath: string
  switchUrl: string
  navLinks: NavLink[]
}

const { locale, currentPath, switchUrl, navLinks } = Astro.props
---

<div
  data-site-nav
  data-visible="true"
  class="site-nav fixed left-0 right-0 top-0 z-nav"
>
  <div
    class="site-nav-bg absolute inset-0 border-b border-white/10 bg-[#0A0A0A]/90 backdrop-blur-md"
  >
  </div>
  <nav
    class="relative mx-auto flex h-[64px] w-full max-w-container items-center justify-between px-5 xl:px-0"
  >
    <div class="hidden items-center gap-12 md:flex">
      <a
        href={localePath(locale, '/')}
        class="flex items-center text-white no-underline"
        aria-label={t(locale, 'header.homepageAriaLabel')}
      >
        <img
          src="/logo-ondrahajek.svg"
          alt="Ondrahajek.com"
          width="137"
          height="13"
          class="h-5 w-auto"
        />
      </a>
      <div class="flex items-center gap-8">
        {
          navLinks.map((item) => (
            <a
              href={item.link}
              class:list={[
                'font-inter text-[1.3rem] text-[#888888] no-underline transition-colors hover:text-white',
                currentPath === item.link && 'font-medium text-white',
              ]}
            >
              {item.text}
            </a>
          ))
        }
      </div>
    </div>

    <a
      href={localePath(locale, '/')}
      class="flex items-center text-white no-underline md:hidden"
      aria-label={t(locale, 'header.homepageAriaLabel')}
    >
      <img
        src="/logo-ondrahajek.svg"
        alt="Ondrahajek.com"
        width="137"
        height="13"
        class="h-4 w-auto"
      />
    </a>

    <div class="flex items-center gap-2 md:hidden">
      <LanguageToggle
        locale={locale}
        switchUrl={switchUrl}
        class="scale-90 border-white/25 text-[1rem]"
      />
      <button
        data-mobile-menu-toggle
        class="relative z-[100] flex h-10 w-10 flex-col items-center justify-center gap-[5px]"
        aria-label={t(locale, 'header.menuToggleAriaLabel')}
      >
        <span
          class="hamburger-line block h-[2px] w-5 bg-white transition-all duration-300"
        ></span>
        <span
          class="hamburger-line block h-[2px] w-5 bg-white transition-all duration-300"
        ></span>
      </button>
    </div>

    {/* Desktop language switch on right */}
    <div class="hidden md:block">
      <LanguageToggle locale={locale} switchUrl={switchUrl} />
    </div>
  </nav>
</div>

<MobileMenuOverlay locale={locale} navLinks={navLinks} />

<style>
  [data-site-nav] {
    transition:
      transform 300ms ease-out,
      opacity 300ms ease-out;
  }

  [data-site-nav][data-visible='false'] {
    transform: translateY(-100%);
    opacity: 0;
  }

  [data-site-nav][data-visible='true'] {
    transform: translateY(0);
    opacity: 1;
  }

  /* Hamburger → X animation */
  [data-mobile-menu-toggle][aria-expanded='true'] .hamburger-line:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }

  [data-mobile-menu-toggle][aria-expanded='true'] .hamburger-line:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }
</style>
