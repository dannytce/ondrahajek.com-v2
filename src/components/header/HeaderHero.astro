---
import DatoImageCover from '~/components/DatoImageCover.astro'
import PlayShowreel from '~/components/PlayShowreel.astro'
import type { ResponsiveImage } from '~/api/generated/types'

interface Props {
  isHomepage: boolean
  compact: boolean
  /** Full viewport height (About page hero). */
  fullViewport?: boolean
  title: string
  /** Breadcrumb third segment (e.g. home.subtitle). */
  subTitle?: string
  homepageHero?: {
    brand: string
    line: string
    tagline: string
    descriptor: string
  }
  headerBackground: ResponsiveImage
}

const {
  isHomepage,
  compact,
  fullViewport = false,
  title,
  subTitle,
  homepageHero,
  headerBackground,
} = Astro.props
const hasAboutOverlay = Astro.slots.has('aboutOverlay')

const gradientStyle = fullViewport
  ? 'linear-gradient(to bottom, rgba(10,10,10,0.78) 0%, rgba(10,10,10,0.12) 38%, rgba(10,10,10,0.88) 100%)'
  : 'linear-gradient(to bottom, rgba(10,10,10,0.80) 0%, rgba(10,10,10,0.05) 40%, rgba(10,10,10,0.70) 100%)'

/**
 * Clear legacy fixed nav (ondrahajek.com): top 30px mobile / 63px md — no bar, Teko links.
 */
const contentPaddingClass = compact
  ? 'pt-[calc(max(30px,env(safe-area-inset-top,0px))+3.5rem)] pb-6 md:pb-8 md:pt-[calc(63px+3.5rem)]'
  : 'pb-8 pt-[calc(max(30px,env(safe-area-inset-top,0px))+5rem)] md:pb-12 md:pt-[calc(63px+6rem)]'

/** About hero: nav clearance + title only; TrustedBy has its own padding. */
const fullViewportTitlePad =
  'pt-[calc(max(30px,env(safe-area-inset-top,0px))+5rem)] pb-6 md:pt-[calc(63px+6rem)] md:pb-8'
---

<header
  class:list={[
    'relative flex w-full flex-col overflow-hidden',
    compact
      ? 'min-h-[220px] justify-end md:min-h-[260px]'
      : isHomepage
        ? 'min-h-[100svh] justify-end md:min-h-screen'
        : fullViewport
          ? 'min-h-[100svh]'
          : 'min-h-[380px] justify-end md:min-h-[520px]',
  ]}
>
  {
    isHomepage ? (
      <div class="absolute inset-0 overflow-hidden" data-hero-video-root>
        <div
          data-hero-poster
          class="pointer-events-none absolute inset-0 z-[1] opacity-100 transition-opacity duration-700"
        >
          <DatoImageCover
            data={{ ...headerBackground, alt: '' }}
            class="absolute inset-0 block size-full min-h-full min-w-full"
            imgClass="h-full w-full object-cover object-center"
            priority
            layout="fill"
            objectFit="cover"
            objectPosition="center"
          />
        </div>
        <video
          class="pointer-events-none absolute inset-0 z-[2] h-full w-full object-cover object-center opacity-0 transition-opacity duration-700"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
          data-hero-video
        >
          <source type="video/mp4" />
        </video>
      </div>
    ) : (
      <div class="absolute inset-0 overflow-hidden">
        <DatoImageCover
          data={{ ...headerBackground, alt: '' }}
          class="pointer-events-none absolute inset-0 z-[1] block size-full min-h-full min-w-full"
          imgClass={`h-full w-full object-cover ${fullViewport ? 'object-[25%_center] md:object-center' : 'object-center'}`}
          priority
          layout="fill"
          objectFit="cover"
          objectPosition={fullViewport ? undefined : 'center'}
        />
      </div>
    )
  }

  {
    /* Mobile: slightly lighter scrim so footage reads through; desktop: original strength */
  }
  <div
    class="pointer-events-none absolute inset-0 z-[2]"
    style={`background: ${gradientStyle}`}
  >
  </div>

  {
    fullViewport ? (
      <div class="relative z-[3] flex min-h-0 w-full flex-1 flex-col">
        {hasAboutOverlay ? (
          <>
            <div class="pointer-events-none absolute inset-0 z-[4] flex items-center justify-center px-6">
              <div class="pointer-events-auto w-full max-w-[640px] text-center">
                <slot name="aboutOverlay" />
              </div>
            </div>
            <div class="flex-1" aria-hidden="true"></div>
          </>
        ) : (
          <div
            class:list={[
              'mx-auto flex w-full max-w-container flex-1 flex-col justify-end gap-5 px-5 xl:px-0',
              fullViewportTitlePad,
            ]}
          >
            {subTitle && (
              <span class="font-geist text-[1.1rem] uppercase tracking-widest text-foreground-muted">
                {subTitle}
              </span>
            )}
            <h1 class="m-0 p-0 font-anton text-[3.4rem] uppercase leading-[0.95] md:text-[5rem]">
              {title}
            </h1>
          </div>
        )}
        <div class="relative z-[3] w-full shrink-0">
          <slot name="trustedBy" />
        </div>
      </div>
    ) : (
      <div
        class:list={[
          'relative z-[3] mx-auto flex w-full flex-col gap-5 px-5',
          isHomepage
            ? 'min-h-[100svh] items-center justify-center text-center md:min-h-screen'
            : `max-w-container xl:px-0 ${contentPaddingClass}`,
        ]}
      >
        {isHomepage && homepageHero ? (
          <>
            <div class="flex items-center justify-center">
              <span class="homepage-hero-tagline font-geist text-[1rem] font-medium uppercase tracking-[0.4em] text-accent-primary">
                {homepageHero.tagline}
              </span>
            </div>
            <h1 class="m-0 mx-auto max-w-[13ch] p-0 font-anton text-[4.8rem] uppercase leading-[1.08] tracking-[0.02em] text-balance sm:max-w-[15ch] md:max-w-[18ch] md:text-[9.6rem] md:leading-[1.06] lg:max-w-[20ch]">
              {homepageHero.line}
            </h1>
            <p class="m-0 max-w-[56ch] font-inter text-[1.4rem] leading-relaxed text-[rgb(255_255_255_/_0.9)] md:max-w-[56ch] md:text-[2.5rem]">
              {homepageHero.descriptor}
            </p>
            <PlayShowreel />
          </>
        ) : (
          <>
            {subTitle && (
              <span class="font-geist text-[1.1rem] uppercase tracking-widest text-foreground-muted">
                {subTitle}
              </span>
            )}
            <h1 class="m-0 p-0 font-anton text-[3.4rem] uppercase leading-[0.95] md:text-[5rem]">
              {title}
            </h1>
          </>
        )}
      </div>
    )
  }
</header>

{isHomepage && <script>import '~/scripts/hero-background-video.ts'</script>}
