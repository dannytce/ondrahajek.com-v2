---
import DatoImageCover from '~/components/DatoImageCover.astro'
import PlayShowreel from '~/components/PlayShowreel.astro'
import type { ResponsiveImage } from '~/api/generated/types'

interface Props {
  isHomepage: boolean
  compact: boolean
  title: string
  subTitle?: string
  homepageHero?: {
    brand: string
    line: string
    descriptor: string
  }
  headerBackground: ResponsiveImage
}

const { isHomepage, compact, title, subTitle, homepageHero, headerBackground } =
  Astro.props
---

<header
  class:list={[
    'relative flex w-full flex-col justify-end overflow-hidden',
    compact
      ? 'min-h-[220px] md:min-h-[260px]'
      : 'min-h-[380px] md:min-h-[520px]',
  ]}
>
  {/* Background image */}
  <div class="absolute inset-0">
    <DatoImageCover
      data={{ ...headerBackground, alt: '' }}
      class="pointer-events-none absolute inset-0 z-[1]"
      imgClass="h-full w-full object-cover"
      priority
      layout="fill"
      objectFit="cover"
    />
  </div>

  {/* Gradient overlay */}
  <div
    class="pointer-events-none absolute inset-0 z-[2]"
    style="background: linear-gradient(to bottom, rgba(10,10,10,0.80) 0%, rgba(10,10,10,0.05) 40%, rgba(10,10,10,0.70) 100%);"
  >
  </div>

  {/* Content */}
  <div
    class="relative z-[3] mx-auto flex w-full max-w-container flex-col gap-5 px-5 pb-8 pt-24 md:pb-12 xl:px-0"
  >
    {
      isHomepage && homepageHero ? (
        <>
          <div class="flex items-center gap-2">
            <span class="font-geist text-[1rem] font-medium uppercase tracking-[0.2em] text-accent-primary">
              {homepageHero.line}
            </span>
            <span class="font-geist text-[1rem] text-foreground-dim">
              &middot;
            </span>
            <span class="font-geist text-[1rem] uppercase tracking-[0.2em] text-foreground-muted">
              VIDEO & PHOTOGRAPHY
            </span>
          </div>
          <h1 class="m-0 max-w-[11ch] p-0 font-anton text-[4.8rem] uppercase leading-[0.9] tracking-[0.02em] md:text-[9.6rem]">
            {homepageHero.line}
          </h1>
          <p class="m-0 max-w-[56ch] font-inter text-[1.4rem] leading-relaxed text-foreground-muted md:text-[1.5rem]">
            {homepageHero.descriptor}
          </p>
          <PlayShowreel />
        </>
      ) : (
        <>
          {subTitle && (
            <span class="font-geist text-[1.1rem] uppercase tracking-widest text-foreground-muted">
              {subTitle}
            </span>
          )}
          <h1 class="m-0 p-0 font-anton text-[3.4rem] uppercase leading-[0.95] md:text-[5rem]">
            {title}
          </h1>
        </>
      )
    }
  </div>
</header>
