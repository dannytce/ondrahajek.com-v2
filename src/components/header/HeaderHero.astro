---
import DatoImageCover from '~/components/DatoImageCover.astro'
import PlayShowreel from '~/components/PlayShowreel.astro'
import type { ResponsiveImage } from '~/api/generated/types'

interface Props {
  isHomepage: boolean
  compact: boolean
  /** Breadcrumb first segment (e.g. home.title — matches design.pen heroBreadcrumb). */
  title: string
  /** Breadcrumb third segment (e.g. home.subtitle). */
  subTitle?: string
  homepageHero?: {
    brand: string
    line: string
    tagline: string
    descriptor: string
  }
  headerBackground: ResponsiveImage
}

const { isHomepage, compact, title, subTitle, homepageHero, headerBackground } = Astro.props
---

<header
  class:list={[
    'relative flex w-full flex-col justify-end overflow-hidden',
    compact
      ? 'min-h-[220px] md:min-h-[260px]'
      : isHomepage
        ? 'min-h-[100svh] md:min-h-screen'
        : 'min-h-[380px] md:min-h-[520px]',
  ]}
>
  {
    isHomepage ? (
      <div class="absolute inset-0 overflow-hidden" data-hero-video-root>
        <div
          data-hero-poster
          class="pointer-events-none absolute inset-0 z-[1] opacity-100 transition-opacity duration-700"
        >
          <DatoImageCover
            data={{ ...headerBackground, alt: '' }}
            class="absolute inset-0 block size-full min-h-full min-w-full"
            imgClass="h-full w-full object-cover object-center"
            priority
            layout="fill"
            objectFit="cover"
            objectPosition="center"
          />
        </div>
        <video
          class="pointer-events-none absolute inset-0 z-[2] h-full w-full object-cover object-center opacity-0 transition-opacity duration-700"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
          data-hero-video
        >
          <source type="video/mp4" />
        </video>
      </div>
    ) : (
      <div class="absolute inset-0 overflow-hidden">
        <DatoImageCover
          data={{ ...headerBackground, alt: '' }}
          class="pointer-events-none absolute inset-0 z-[1] block size-full min-h-full min-w-full"
          imgClass="h-full w-full object-cover object-center"
          priority
          layout="fill"
          objectFit="cover"
          objectPosition="center"
        />
      </div>
    )
  }

  {/* Gradient overlay */}
  <div
    class="pointer-events-none absolute inset-0 z-[2]"
    style="background: linear-gradient(to bottom, rgba(10,10,10,0.80) 0%, rgba(10,10,10,0.05) 40%, rgba(10,10,10,0.70) 100%);"
  >
  </div>

  {/* Content */}
  <div
    class="relative z-[3] mx-auto flex w-full max-w-container flex-col gap-5 px-5 pb-8 pt-24 md:pb-12 xl:px-0"
  >
    {
      isHomepage && homepageHero ? (
        <>
          {/* Matches design.pen heroBreadcrumb (Bsxvs): Geist Mono 11px, gap-2, uppercase */}
          <p
            class="m-0 flex flex-wrap items-center gap-2 font-geist text-[0.625rem] font-normal uppercase leading-none tracking-[0.14em] text-foreground-muted md:text-[11px] md:tracking-[0.18em]"
          >
            <span class="font-medium text-accent-primary">{homepageHero.tagline}</span>
            <span aria-hidden="true" class="select-none">&middot;</span>
            <span>{subTitle}</span>
          </p>
          <h1
            class="m-0 max-w-[min(100%,42rem)] whitespace-pre-line p-0 font-anton text-[3rem] leading-[1.05] tracking-[0.01em] md:text-[4.5rem] md:leading-[1.04]"
          >
            {homepageHero.line}.
          </h1>
          <p class="m-0 max-w-[56ch] font-inter text-sm leading-relaxed text-foreground-muted md:text-base">
            {homepageHero.descriptor}
          </p>
          <PlayShowreel />
        </>
      ) : (
        <>
          <h1 class="m-0 p-0 font-anton text-[3.4rem] uppercase leading-[0.95] md:text-[5rem]">
            {title}
          </h1>
        </>
      )
    }
  </div>
</header>

{isHomepage && (
  <script>
    import '~/scripts/hero-background-video.ts'
  </script>
)}
