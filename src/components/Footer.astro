---
import { localePath, type Locale } from '~/i18n'
import { localizedPagePath } from '~/i18n/routes'

interface Props {
  locale?: Locale
}

const { locale = 'en' } = Astro.props

const workLinks = [
  {
    text: locale === 'cs' ? 'Letecké záběry' : 'Drone',
    href: localePath(locale, localizedPagePath(locale, 'drone')),
  },
  {
    text: locale === 'cs' ? 'Video' : 'Video',
    href: localePath(locale, localizedPagePath(locale, 'video')),
  },
  {
    text: locale === 'cs' ? 'Galerie' : 'Gallery',
    href: localePath(locale, localizedPagePath(locale, 'gallery')),
  },
]

const infoLinks = [
  {
    text: locale === 'cs' ? 'O mně' : 'About',
    href: localePath(locale, localizedPagePath(locale, 'about')),
  },
]
---

<footer class="mt-16 border-t border-border-subtle md:mt-24">
  <div class="mx-auto max-w-container px-[15px] py-12 md:py-16 xl:px-0">
    <div class="grid gap-10 md:grid-cols-3 md:gap-8">
      {/* Logo + tagline */}
      <div class="flex flex-col gap-3">
        <a href={localePath(locale, '/')} class="inline-block">
          <img src="/logo-ondrahajek.svg" alt="ONDRAHAJEK.COM" class="h-5" />
        </a>
        <p class="m-0 max-w-[28ch] font-inter text-[1.3rem] leading-relaxed text-foreground-muted">
          {locale === 'cs'
            ? 'Špičková letecká kinematografie a video produkce.'
            : 'High-end aerial cinematography & video production.'}
        </p>
      </div>

      {/* Links */}
      <div class="grid grid-cols-2 gap-8">
        <div class="flex flex-col gap-3">
          <h4 class="m-0 font-geist text-[1.1rem] uppercase tracking-widest text-foreground-dim">
            {locale === 'cs' ? 'Práce' : 'Work'}
          </h4>
          {workLinks.map((link) => (
            <a
              href={link.href}
              class="font-inter text-[1.3rem] text-foreground-muted no-underline transition-colors hover:text-white"
            >
              {link.text}
            </a>
          ))}
        </div>
        <div class="flex flex-col gap-3">
          <h4 class="m-0 font-geist text-[1.1rem] uppercase tracking-widest text-foreground-dim">
            Info
          </h4>
          {infoLinks.map((link) => (
            <a
              href={link.href}
              class="font-inter text-[1.3rem] text-foreground-muted no-underline transition-colors hover:text-white"
            >
              {link.text}
            </a>
          ))}
        </div>
      </div>

      {/* Contact + socials */}
      <div class="flex flex-col gap-3">
        <h4 class="m-0 font-geist text-[1.1rem] uppercase tracking-widest text-foreground-dim">
          {locale === 'cs' ? 'Kontakt' : 'Contact'}
        </h4>
        <a
          href="mailto:info@ondrahajek.com"
          class="font-inter text-[1.3rem] text-foreground-muted no-underline transition-colors hover:text-white"
        >
          info@ondrahajek.com
        </a>
        <a
          href="tel:+420773604400"
          class="font-inter text-[1.3rem] text-foreground-muted no-underline transition-colors hover:text-white"
        >
          +420 773 604 400
        </a>
        <div class="mt-2 flex gap-4">
          <a href="https://www.linkedin.com/in/ondrahajek/" target="_blank" rel="noopener" class="font-inter text-[1.2rem] text-foreground-dim no-underline transition-colors hover:text-white">
            LinkedIn
          </a>
          <a href="https://www.instagram.com/ondrahajek.drone/" target="_blank" rel="noopener" class="font-inter text-[1.2rem] text-foreground-dim no-underline transition-colors hover:text-white">
            Instagram
          </a>
          <a href="https://vimeo.com/ondrahajek" target="_blank" rel="noopener" class="font-inter text-[1.2rem] text-foreground-dim no-underline transition-colors hover:text-white">
            Vimeo
          </a>
        </div>
      </div>
    </div>

    {/* Bottom bar */}
    <div class="mt-12 border-t border-border-subtle pt-6 text-center">
      <p class="m-0 font-geist text-[1.1rem] text-foreground-dim">
        &copy; {new Date().getFullYear()} Ondřej Hájek
      </p>
    </div>
  </div>
</footer>
