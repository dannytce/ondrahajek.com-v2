---
import { localePath, type Locale } from '~/i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

const footerLinks = [
  { title: 'Go and see the', name: 'Gallery', link: localePath(locale, '/gallery') },
  { title: 'Read something', name: 'About me', link: localePath(locale, '/about') },
  { title: 'Check out my', name: 'Portfolio', link: localePath(locale, '/') },
  { title: 'Hit me up on', name: 'info', email: 'info@ondrahajek.com', phone: '+420 773 604 400' },
];
---

<footer class="py-16 px-6 pb-24 mt-0 md:py-[50px] md:px-0 md:pt-0 md:h-[80vh] md:flex md:mt-[100px]">
  <div class="w-full flex flex-col gap-0 md:flex-row md:flex-nowrap">
    {footerLinks.map((item, index) =>
      item.link ? (
        <a
          href={item.link}
          class:list={[
            'w-full min-h-[120px] py-8 flex flex-col justify-center text-center border-b border-white/10 last:border-b-0 md:border-b-0 md:h-full md:flex-1 md:py-0 md:transition-colors md:hover:bg-[#17171a]',
            index === 1 && 'md:bg-[#111114]',
          ]}
        >
          <p class="p-0 m-0 mb-5 text-secondary font-roboto normal-case text-[1.8rem]">
            {item.title}
          </p>
          <h3 class="m-0 p-0 text-[4rem] leading-6 uppercase text-primary font-teko no-underline">
            {item.name}
          </h3>
        </a>
      ) : (
        <div class="w-full min-h-[120px] py-8 flex flex-col justify-center text-center border-b border-white/10 last:border-b-0 md:border-b-0 md:h-full md:flex-1 md:py-0 md:transition-colors md:hover:bg-[#17171a]">
          <p class="p-0 m-0 mb-5 text-secondary font-roboto normal-case text-[1.8rem]">
            {item.title}
          </p>
          <h3 class="m-0 p-0 text-[4rem] leading-6 uppercase text-primary font-teko">
            <a href={`mailto:${item.email}`} class="no-underline text-primary">
              {item.name}
              <span class="block text-[2rem]">@{item.email?.split('@')[1]}</span>
            </a>
          </h3>
          <a
            href={`tel:${item.phone?.replace(/\s/g, '')}`}
            class="font-teko no-underline text-secondary text-[2rem]"
          >
            {item.phone}
          </a>
        </div>
      )
    )}
  </div>
</footer>
