---
const footerLinks = [
  { title: 'Go and see the', name: 'Gallery', link: '/gallery' },
  { title: 'Read something', name: 'About me', link: '/about' },
  { title: 'Check out my', name: 'Portfolio', link: '/' },
  { title: 'Hit me up on', name: 'info', email: 'info@ondrahajek.com', phone: '+420 773 604 400' },
];
---

<footer class="py-[100px] px-0 pb-[125px] mt-0 md:py-[50px] md:pt-0 md:h-[80vh] md:flex md:mt-[100px]">
  <div class="w-full max-w-container mx-auto px-[15px] xl:px-0 flex flex-wrap md:flex-nowrap md:flex-row">
    {footerLinks.map((item, index) =>
      item.link ? (
        <a
          href={item.link}
          class:list={[
            'h-[155px] md:h-full flex-1 flex flex-col justify-center text-center md:flex md:transition-colors md:hover:bg-[#17171a]',
            index === 1 && 'md:bg-[#111114]',
          ]}
        >
          <p class="p-0 m-0 mb-5 text-secondary font-roboto normal-case text-[1.8rem]">
            {item.title}
          </p>
          <h3 class="m-0 p-0 text-[4rem] leading-6 uppercase text-primary font-teko no-underline">
            {item.name}
          </h3>
        </a>
      ) : (
        <div class="h-[155px] md:h-full flex-1 flex flex-col justify-center text-center md:transition-colors md:hover:bg-[#17171a]">
          <p class="p-0 m-0 mb-5 text-secondary font-roboto normal-case text-[1.8rem]">
            {item.title}
          </p>
          <h3 class="m-0 p-0 text-[4rem] leading-6 uppercase text-primary font-teko">
            <a href={`mailto:${item.email}`} class="no-underline text-primary">
              {item.name}
              <span class="block text-[2rem]">@{item.email?.split('@')[1]}</span>
            </a>
          </h3>
          <a
            href={`tel:${item.phone?.replace(/\s/g, '')}`}
            class="font-teko no-underline text-secondary text-[2rem]"
          >
            {item.phone}
          </a>
        </div>
      )
    )}
  </div>
</footer>
