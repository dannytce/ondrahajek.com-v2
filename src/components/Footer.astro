---
import { t, localePath, type Locale } from '~/i18n'
import { localizedPagePath, portfolioSegment } from '~/i18n/routes'
import { SOCIAL_LINKS } from '~/config/social'

interface Props {
  locale?: Locale
}

const { locale = 'en' } = Astro.props
const pathname = Astro.url.pathname
const homePath = localePath(locale, '/')

const workLinks = [
  {
    text: t(locale, 'nav.drone'),
    href: localePath(locale, localizedPagePath(locale, 'drone')),
  },
  {
    text: t(locale, 'nav.video'),
    href: localePath(locale, localizedPagePath(locale, 'video')),
  },
  {
    text: t(locale, 'nav.gallery'),
    href: localePath(locale, localizedPagePath(locale, 'gallery')),
  },
]

const infoLinks = [
  {
    text: t(locale, 'nav.about'),
    href: localePath(locale, localizedPagePath(locale, 'about')),
  },
]

const dronePath = localePath(locale, localizedPagePath(locale, 'drone'))
const videoPath = localePath(locale, localizedPagePath(locale, 'video'))
const portfolioBasePath = localePath(locale, `/${portfolioSegment(locale)}`)
const isCategoryHubPage = pathname === dronePath || pathname === videoPath
const isHomePage = pathname === homePath
const isDetailPage = pathname.startsWith(`${portfolioBasePath}/`)

const mobileCategoryLinks = [
  {
    text: t(locale, 'footer.mobile.drone'),
    href: dronePath,
  },
  {
    text: t(locale, 'footer.mobile.video'),
    href: videoPath,
  },
  {
    text: t(locale, 'footer.mobile.gallery'),
    href: localePath(locale, localizedPagePath(locale, 'gallery')),
  },
  {
    text: t(locale, 'footer.mobile.about'),
    href: localePath(locale, localizedPagePath(locale, 'about')),
  },
]

const mobileLinks = isCategoryHubPage || isHomePage || isDetailPage
  ? mobileCategoryLinks
  : workLinks

const contactHref = localePath(locale, localizedPagePath(locale, 'about'))
---

<footer class="mt-16 border-t border-white/10">
  <div class="mx-auto max-w-container px-5 py-8 md:hidden">
    <div class="flex flex-col gap-8">
      <div class="flex flex-col gap-2">
        <a href={localePath(locale, '/')} class="font-anton text-[1.3rem] tracking-[0.06em] text-white no-underline">
          ONDRAHAJEK.COM
        </a>
        <p class="m-0 font-inter text-[1.2rem] text-[#888888]">{t(locale, 'footer.tagline')}</p>
      </div>

      <div class="flex gap-6">
        {mobileLinks.map((link) => (
          <a href={link.href} class="font-inter text-[1.2rem] text-[#888888] no-underline transition-colors hover:text-white">
            {link.text}
          </a>
        ))}
      </div>

      <div class="flex flex-col gap-1.5">
        <a href="mailto:ondra@ondrahajek.com" class="font-geist text-[1.1rem] text-[#4A9FD8] no-underline transition-colors hover:text-white">
          ondra@ondrahajek.com
        </a>
        <a href="tel:+420773604400" class="font-geist text-[1.1rem] text-[#888888] no-underline transition-colors hover:text-white">
          +420 773 604 400
        </a>
      </div>

      <div class="flex items-center justify-between">
        <p class="m-0 font-geist text-[0.9rem] text-[#555555]">© 2016–{new Date().getFullYear()} Ondřej Hájek</p>
        <div class="flex gap-4">
          <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener" class="font-inter text-[1.1rem] text-[#888888] no-underline transition-colors hover:text-white">{t(locale, 'footer.social.linkedin')}</a>
          <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener" class="font-inter text-[1.1rem] text-[#888888] no-underline transition-colors hover:text-white">{t(locale, 'footer.social.instagram')}</a>
          <a href={SOCIAL_LINKS.vimeo} target="_blank" rel="noopener" class="font-inter text-[1.1rem] text-[#888888] no-underline transition-colors hover:text-white">{t(locale, 'footer.social.vimeo')}</a>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto hidden max-w-container px-10 py-10 md:block xl:px-0">
    <div class="flex items-start justify-between gap-12">
      <div class="flex flex-col gap-3">
        <a href={localePath(locale, '/')} class="font-anton text-[1.4rem] tracking-[0.08em] text-white no-underline">
          ONDRAHAJEK.COM
        </a>
        <p class="m-0 font-inter text-[1.2rem] text-[#888888]">{t(locale, 'footer.tagline')}</p>
        <p class="m-0 font-geist text-[1rem] text-[#555555]">© 2016–{new Date().getFullYear()} Ondřej Hájek</p>
      </div>

      <div class="flex gap-12">
        <div class="flex flex-col gap-3">
          <p class="m-0 font-inter text-[1.2rem] font-semibold text-white">{t(locale, 'footer.work')}</p>
          {workLinks.map((link) => (
            <a href={link.href} class="font-inter text-[1.2rem] text-[#888888] no-underline transition-colors hover:text-white">
              {link.text}
            </a>
          ))}
        </div>
        <div class="flex flex-col gap-3">
          <p class="m-0 font-inter text-[1.2rem] font-semibold text-white">{t(locale, 'footer.info')}</p>
          {infoLinks.map((link) => (
            <a href={link.href} class="font-inter text-[1.2rem] text-[#888888] no-underline transition-colors hover:text-white">
              {link.text}
            </a>
          ))}
          <a href={contactHref} class="font-inter text-[1.2rem] text-[#888888] no-underline transition-colors hover:text-white">
            {t(locale, 'footer.contact')}
          </a>
        </div>
      </div>

      <div class="flex flex-col items-end gap-3">
        <a href="mailto:ondra@ondrahajek.com" class="font-geist text-[1.2rem] text-[#4A9FD8] no-underline transition-colors hover:text-white">
          ondra@ondrahajek.com
        </a>
        <a href="tel:+420773604400" class="font-geist text-[1.2rem] text-[#888888] no-underline transition-colors hover:text-white">
          +420 773 604 400
        </a>
        <div class="flex gap-4">
          <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener" class="font-inter text-[1.2rem] text-[#888888] no-underline transition-colors hover:text-white">{t(locale, 'footer.social.linkedin')}</a>
          <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener" class="font-inter text-[1.2rem] text-[#888888] no-underline transition-colors hover:text-white">{t(locale, 'footer.social.instagram')}</a>
          <a href={SOCIAL_LINKS.vimeo} target="_blank" rel="noopener" class="font-inter text-[1.2rem] text-[#888888] no-underline transition-colors hover:text-white">{t(locale, 'footer.social.vimeo')}</a>
        </div>
      </div>
    </div>
  </div>
</footer>
