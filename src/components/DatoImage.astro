---
import { Image } from '@datocms/astro';
import type { ResponsiveImage } from '~/api/generated/types';

interface Props {
  data: ResponsiveImage & { alt?: string };
  class?: string;
  priority?: boolean;
  sizes?: string;
}

const { data, class: className, priority = false, sizes } = Astro.props;
---

<Image
  data={data}
  imgClass={className}
  priority={priority}
  sizes={sizes}
/>
