---
import Footer from './Footer.astro'
import HireProjectDrawer from './HireProjectDrawer.astro'
import type { Locale } from '~/i18n'

interface Props {
  isHomepage?: boolean
  isAboutPage?: boolean
  locale?: Locale
}

const { isHomepage, locale = 'en' } = Astro.props
---

<slot name="header" />
<main
  id={isHomepage ? 'portfolio' : undefined}
  class="relative bg-surface-dark"
>
  <slot />
  <Footer locale={locale} />
</main>
